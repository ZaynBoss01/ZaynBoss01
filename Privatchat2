local function sendHeartbeat()
    safeCall(function()
        HttpService:PostAsync(API_URL .. "/heartbeat", HttpService:JSONEncode({
            user = Player.Name,
            scriptId = SCRIPT_ID,
            time = os.time()
        }))
    end)
end

local function cleanupUsers()
    safeCall(function()
        local response = HttpService:GetAsync(API_URL .. "/active")
        local active = HttpService:JSONDecode(response)
        
        if type(active) == "table" then
            local newActive = {}
            for _, user in ipairs(activeUsers) do
                for _, a in ipairs(active) do
                    if a.user == user then
                        table.insert(newActive, user)
                        break
                    end
                end
            end
            
            for _, user in ipairs(activeUsers) do
                local found = false
                for _, n in ipairs(newActive) do
                    if n == user then
                        found = true
                        break
                    end
                end
                if not found and user ~= Player.Name then
                    addSystemMessage("👋 " .. user .. " left the chat!")
                end
            end
            
            activeUsers = newActive
            if not table.find(activeUsers, Player.Name) then
                table.insert(activeUsers, 1, Player.Name)
            end
            updateActiveCount()
        end
    end)
end

