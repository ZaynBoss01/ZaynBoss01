    if count == 0 then
        onlineLabel.Text = "👥 Active: 1 (You)"
        if not table.find(activeUsers, Player.Name) then
            table.insert(activeUsers, Player.Name)
        end
    else
        onlineLabel.Text = "👥 Active: " .. count
    end
end

-- ============================================
-- SEND MESSAGE
-- ============================================
local function sendMessage(msg)
    if msg == "" or not msg then return end
    
    local role = SUPER_ADMINS[Player.Name] and "OWNER" or "USER"
    local prefix = role == "OWNER" and "👑 [OWNER] " or "👤 [USER] "
    
    addMessage(prefix .. Player.Name .. ": " .. msg, Color3.new(1, 1, 1))
    
    -- Bubble Chat
    safeCall(function()
        if Player.Character and Player.Character:FindFirstChild("Head") then
            local bubble = Instance.new("BillboardGui")
            bubble.Size = UDim2.new(0, 200, 0, 40)
            bubble.StudsOffset = Vector3.new(0, 2.5, 0)
            bubble.AlwaysOnTop = true
            bubble.Parent = Player.Character.Head
            
            local text = Instance.new("TextLabel")
            text.Size = UDim2.new(1, 0, 1, 0)
            text.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            text.BackgroundTransparency = 0.4
            text.TextColor3 = Color3.new(1, 1, 1)
            text.Text = msg
            text.Font = Enum.Font.GothamMedium
            text.TextSize = 12
            text.TextWrapped = true
            text.Parent = bubble
            Instance.new("UICorner", text).CornerRadius = UDim.new(0, 8)
            
            game:GetService("Debris"):AddItem(bubble, 3)
        end
    end)
    
    -- Send to server
    safeCall(function()
        local msgId = os.time() .. Player.Name .. math.random(10000, 99999)
        HttpService:PostAsync(API_URL, HttpService:JSONEncode({
            id = msgId,
            user = Player.Name,
            msg = msg,
            role = role,
            scriptId = SCRIPT_ID,
            version = SCRIPT_VERSION,
            time = os.time()
        }))
    end)
end

-- ============================================
-- RECEIVE MESSAGES
-- ============================================
local function fetchMessages()
    safeCall(function()
        local response = HttpService:GetAsync(API_URL)
        local data = HttpService:JSONDecode(response)
        
        if type(data) == "table" then
            for _, msg in ipairs(data) do
                local msgId = tostring(msg.id)
                
                if msgId and msgId ~= tostring(lastMessageId) and 
                   msg.user ~= Player.Name and 
                   msg.scriptId == SCRIPT_ID then
                    
                    local alreadySeen = false
                    for _, seen in ipairs(messageHistory) do
                        if seen == msgId then
                            alreadySeen = true
                            break
                        end
                    end
                    
                    if not alreadySeen then
                        lastMessageId = msgId
                        table.insert(messageHistory, msgId)
                        if #messageHistory > 200 then
                            table.remove(messageHistory, 1)
                        end
                        
                        -- Add to active users
                        local userExists = false
                        for _, u in ipairs(activeUsers) do
                            if u == msg.user then
                                userExists = true
                                break
                            end
                        end
                        if not userExists then
                            table.insert(activeUsers, msg.user)
                            updateActiveCount()
                            addSystemMessage("✨ " .. msg.user .. " joined the chat!")
                        end
                        
                        -- Show message (NO HTML COLOR CODES)
                        if msg.role == "OWNER" then
                            addMessage("👑 [OWNER] " .. msg.user .. ": " .. msg.msg, Color3.new(1, 1, 1))
                        else
                            addMessage("👤 [USER] " .. msg.user .. ": " .. msg.msg, Color3.new(1, 1, 1))
                        end
                    end
                end
            end
        end
    end)
end

