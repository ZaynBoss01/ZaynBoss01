local B64_CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
local function B64Encode(data)
    return ((data:gsub('.', function(x)
        local r,b='',string.byte(x)
        for i=8,1,-1 do r=r..(b%2^i-b%2^(i-1)>0 and '1' or '0') end
        return r;
    end)..'0000'):gsub('%d%d%d?%d?%d?%d?', function(x)
        if (#x < 6) then return '' end
        local c=0
        for i=1,6 do c=c+(x:sub(i,i)=='1' and 2^(6-i) or 0) end
        return string.sub(B64_CHARS, c+1, c+1)
    end)..({ '', '==', '=' })[#data%3+1])
end
local function B64Decode(data)
    data = string.gsub(data, '[^'..B64_CHARS..'=]', '')
    return (data:gsub('.', function(x)
        if (x == '=') then return '' end
        local r,f='', (string.find(B64_CHARS, x)-1)
        for i=6,1,-1 do r=r..(f%2^i-f%2^(i-1)>0 and '1' or '0') end
        return r;
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if (#x ~= 8) then return '' end
        local c=0
        for i=1,8 do c=c+(string.sub(x,i,i)=='1' and 2^(8-i) or 0) end
        return string.char(c)
    end))
end

local SERVER_E2EE_KEY = "NEXUS_SERVER_SECURE_101"
local function E2EE_Encrypt(text, key)
    if not text or not key then return text end
    local res = ""
    for i = 1, #text do res = res .. string.char(bit32.bxor(string.byte(text, i), string.byte(key, ((i - 1) % #key) + 1))) end
    return "E2EE::" .. B64Encode(res)
end
local function E2EE_Decrypt(text, key)
    if not text or not key or not tostring(text):match("^E2EE::") then return text end
    local decoded = B64Decode(text:gsub("^E2EE::", ""))
    local res = ""
    for i = 1, #decoded do res = res .. string.char(bit32.bxor(string.byte(decoded, i), string.byte(key, ((i - 1) % #key) + 1))) end
    return res
end

