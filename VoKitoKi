local function translateText(text, dictionary)
    text = string.upper(text)
    local result = ""
    for i = 1, #text do
        local char = text:sub(i, i)
        result = result .. (dictionary[char] or char)
    end
    return result
end

local function applyFontStyle(text, styleIndex)
    local upperText = string.upper(text)
    local reversed = string.reverse(text)
    local wideText = ""
    for i = 1, #upperText do wideText = wideText .. upperText:sub(i,i) .. " " end

    if styleIndex == 1 then return translateText(text, fontMaps.SmallCaps)
    elseif styleIndex == 2 then return translateText(text, fontMaps.Cyrillic)
    elseif styleIndex == 3 then return translateText(text, fontMaps.Crossed)
    elseif styleIndex == 4 then return translateText(text, fontMaps.Squared)
    elseif styleIndex == 5 then return translateText(text, fontMaps.BoldBox)
    elseif styleIndex == 6 then return translateText(text, fontMaps.Circled)
    elseif styleIndex == 7 then return translateText(text, fontMaps.Kanji)
    elseif styleIndex == 8 then return translateText(text, fontMaps.Japanese)
    elseif styleIndex == 9 then local res = ""; for i=1, #text do res = res..text:sub(i,i).."҉" end return res
    elseif styleIndex == 10 then return "『" .. upperText .. "』"
    elseif styleIndex == 11 then return "⭐" .. upperText .. "⭐"
    elseif styleIndex == 12 then return "✨" .. upperText .. "✨"
    elseif styleIndex == 13 then return "👑" .. upperText .. "👑"
    elseif styleIndex == 14 then return "❤️" .. upperText .. "❤️"
    elseif styleIndex == 15 then return "🕷️" .. upperText .. "🕸️"
    elseif styleIndex == 16 then return "~" .. upperText .. "~"
    elseif styleIndex == 17 then return "⚡" .. upperText .. "⚡"
    elseif styleIndex == 18 then return "🌸" .. upperText .. "🌸"
    elseif styleIndex == 19 then return "🕸️ " .. reversed .. " 🕸️"
    elseif styleIndex == 20 then return "【" .. wideText .. "】"
    end
    return upperText
end

