-- Polling Loops
local processedServerIds = {}
local processedDmIds = {}

task.spawn(function()
    while getgenv().NEXUS_CHAT_RUNNING do
        pcall(function()
            -- Poll Server
            local sRes = reqFunc({UrlParams = DB_PATH .. '.json?orderBy="$key"&limitToLast=15', Method = "GET"})
            if sRes.Success and sRes.Body ~= "null" then
                local data = HttpService:JSONDecode(sRes.Body)
                for key, msgData in pairs(data) do
                    if not processedServerIds[key] then
                        processedServerIds[key] = true
                        local mtext = msgData.text
                        local senderPart, msgPart, uidPart = mtext:match("^(.-):%s(.+)%s*||([%w_]+)$")
                        if senderPart and msgPart and uidPart ~= myUserId then
                            local decMsg = E2EE_Decrypt(msgPart, SERVER_E2EE_KEY)
                            BuildMessageBubble(ServerScroll, senderPart, decMsg, false)
                        end
                    end
                end
            end
            
            -- Poll DMs
            local dRes = reqFunc({UrlParams = "global_dms/" .. myUserId .. ".json", Method = "GET"})
            if dRes.Success and dRes.Body ~= "null" then
                local dms = HttpService:JSONDecode(dRes.Body)
                for mKey, mVal in pairs(dms) do
                    if not processedDmIds[mKey] then
                        processedDmIds[mKey] = true
                        local sUid = tostring(mVal.senderId)
                        local dmKey = getDmConvoKey(myUserId, sUid) .. "_DM_SECURE"
                        local decText = E2EE_Decrypt(mVal.text, dmKey)
                        
                        if activeTab == "DM" and activeDmTarget == sUid then
                            BuildMessageBubble(DMScroll, mVal.senderName, decText, false)
                        else
                            -- Show tiny notification on button if not viewing
                            TabDM.Text = "📩 Messages (*)"
                            task.delay(3, function() TabDM.Text = "📩 Messages" end)
                        end
                        reqFunc({UrlParams = "global_dms/" .. myUserId .. "/" .. mKey .. ".json", Method = "DELETE"})
                    end
                end
            end
        end)
        task.wait(2)
    end
end)
