local function BuildMessageBubble(container, name, text, isMine)
    local frame = Instance.new("Frame", container)
    frame.Size = UDim2.new(1, 0, 0, 0)
    frame.AutomaticSize = Enum.AutomaticSize.Y
    frame.BackgroundTransparency = 1

    local bubble = Instance.new("Frame", frame)
    bubble.BackgroundColor3 = isMine and Colors.BubbleMe or Colors.BubbleOther
    bubble.AutomaticSize = Enum.AutomaticSize.XY
    Instance.new("UICorner", bubble).CornerRadius = UDim.new(0, 8)
    local pad = Instance.new("UIPadding", bubble)
    pad.PaddingTop = UDim.new(0,6); pad.PaddingBottom = UDim.new(0,6); pad.PaddingLeft = UDim.new(0,10); pad.PaddingRight = UDim.new(0,10)

    if isMine then
        bubble.AnchorPoint = Vector2.new(1, 0)
        bubble.Position = UDim2.new(1, 0, 0, 0)
    end

    local txt = Instance.new("TextLabel", bubble)
    txt.BackgroundTransparency = 1
    txt.Text = "<b>" .. name .. "</b>\n" .. text
    txt.RichText = true
    txt.Font = Enum.Font.Gotham
    txt.TextSize = 12
    txt.TextColor3 = Colors.TextWhite
    txt.TextXAlignment = isMine and Enum.TextXAlignment.Right or Enum.TextXAlignment.Left
    txt.AutomaticSize = Enum.AutomaticSize.XY
    txt.TextWrapped = true
    
    local constraint = Instance.new("UISizeConstraint", txt)
    constraint.MaxSize = Vector2.new(250, 9999)
    
    -- Auto scroll
    task.delay(0.1, function()
        container.CanvasPosition = Vector2.new(0, container.AbsoluteWindowSize.Y + 9999)
    end)
end

local function ProcessQueue()
    task.spawn(function()
        while #messageQueue > 0 do
            local msg = table.remove(messageQueue, 1)
            pcall(reqFunc, {UrlParams = DB_PATH .. ".json", Method = "POST", Body = HttpService:JSONEncode(msg)})
            task.wait(0.2)
        end
    end)
end

