    sendDmMsg = function(txt, targetUid)
        txt = tostring(txt):gsub("^%s+", ""):gsub("%s+$", "")
        if txt == "" or not targetUid then return end
        local targetUidStr = tostring(targetUid)
        if dmReplyContext and not txt:find("%[STICKER:") and not txt:find("%[PHOTO:") and not txt:find("%[VOICE:") then
            txt = "↪️ [Replying to " .. dmReplyContext .. "]\n" .. txt
            updateDmReplyState(nil, nil)
        end
        local myDmMsgFrame = addMessageToChat(cleanMyName, txt, false, myUserId, "DM", "", targetUid)
        local convoKey = getDmConvoKey(myUserId, targetUid)
        local senderProfile = customProfiles[myUserId] or {}
        local myDp = senderProfile.dp or ""
        if saveDmContact then saveDmContact(targetUid, cleanMyName, myUser, myDp, txt) end
        task.spawn(function()
            local ts = os.time()
            local dmHistoryData = {senderId = myUserId, senderName = cleanMyName, text = txt, timestamp = ts}
            pcall(function()
                local res = reqFunc({Url = FIREBASE_URL .. "dm_history/" .. convoKey .. ".json", Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(dmHistoryData)})
                if res and res.Body then
                    local decoded = HttpService:JSONDecode(res.Body)
                    if decoded and decoded.name and myDmMsgFrame then
                        myDmMsgFrame:SetAttribute("FBKey", decoded.name)
                        -- ConvoKey attribute bhi set karo unsend ke liye
                        myDmMsgFrame:SetAttribute("ConvoKey", convoKey)
                    end
                end
            end)
            -- ================================================================= --
            -- FIX: global_dms payload mein senderId include karo
            -- Receiver ko pata chalega ki kis convoKey se delete karna hai
            -- ================================================================= --
            local dmPayload = {senderId = myUserId, senderName = cleanMyName, text = txt, timestamp = ts}
            pcall(function()
                reqFunc({Url = FIREBASE_URL .. "global_dms/" .. targetUidStr .. ".json", Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(dmPayload)})
            end)
        end)
    end

