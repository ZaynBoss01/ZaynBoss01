        Url = PROXY_URL,
        Method = "POST", 
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode({
            secret_key = SECRET_KEY,
            method = method,
            path = path,
            body = options.Body
        })
    }

    local s, r = pcall(_EXEC_REQ, requestData)
    
    if s and r then
        return r
    else
        return {Success = false, Body = "REQUEST_FAILED"}
    end
end

