    local function StopZaynDJ()
        globalDjSequence = globalDjSequence + 1
        if currentDjSound then
            pcall(function() currentDjSound:Stop(); currentDjSound:Destroy() end)
            currentDjSound = nil
        end
        if getgenv and getgenv().ZAYN_DJ_SOUND_REF then
            pcall(function() getgenv().ZAYN_DJ_SOUND_REF:Stop(); getgenv().ZAYN_DJ_SOUND_REF:Destroy() end)
            getgenv().ZAYN_DJ_SOUND_REF = nil
        end
        for _, child in ipairs(djFolder:GetChildren()) do
            if child:IsA("Sound") then pcall(function() child:Stop(); child:Destroy() end) end
        end
        if currentDjFileName and delfile and isfile and isfile(currentDjFileName) then
            pcall(function() delfile(currentDjFileName) end)
        end
        currentDjFileName = nil
        if lastDjPlayFirebaseKey and lastDjPlayFirebaseKey ~= "" then
            task.spawn(function()
                pcall(function()
                    reqFunc({Url = FIREBASE_URL .. DB_PATH .. "/" .. lastDjPlayFirebaseKey .. ".json", Method = "DELETE"})
                end)
                lastDjPlayFirebaseKey = nil
            end)
        end
        removeMusicBubble()
    end

