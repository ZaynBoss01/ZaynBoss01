                        end
                    end)

                    bubbleFrame.InputChanged:Connect(function(input)
                        if startPos and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                            local delta = input.Position - startPos
                            local absDX = math.abs(delta.X); local absDY = math.abs(delta.Y)
                            if delta.Magnitude > 5 then
                                hasMoved = true
                                if isHolding and holdConn then holdConn:Disconnect(); holdConn = nil end
