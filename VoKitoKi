local function trim(s) return s:match("^%s*(.-)%s*$") end

local function getTargetPlayer()
    if targetUsername == "" or targetUsername == " " then return LocalPlayer end
    for _, p in pairs(Players:GetPlayers()) do
        if string.find(string.lower(p.Name), string.lower(targetUsername)) or 
           string.find(string.lower(p.DisplayName), string.lower(targetUsername)) then
            return p
        end
    end
    return LocalPlayer
end

local function grabProps()
    orbitProps = {}
    local wsCom = Workspace:FindFirstChild("WorkspaceCom")
    if not wsCom then return end

    for _, category in pairs(wsCom:GetChildren()) do
        for _, prop in pairs(category:GetChildren()) do
            if chaosModeEnabled or 
               string.find(prop.Name, LocalPlayer.Name) or 
               string.find(string.lower(prop.Name), "mickeygotban") or 
               string.find(string.lower(prop.Name), "zayn") or
               prop:FindFirstChild("SetCurrentCFrame") then
                
                local remote = prop:FindFirstChild("SetCurrentCFrame")
                if remote and remote:IsA("RemoteFunction") then
                    local visualPart = prop:FindFirstChildWhichIsA("BasePart") or prop.PrimaryPart
                    table.insert(orbitProps, { Remote = remote, Part = visualPart, PropObj = prop })
                end
            end
        end
    end
end

