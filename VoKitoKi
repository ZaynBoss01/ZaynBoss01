                        elseif orbitStyle == "Spiral" then local sr = orbitRadius + math.sin(t * 2) * (orbitRadius / 2) x, z = math.cos(angle) * sr, math.sin(angle) * sr
                        elseif orbitStyle == "Figure-8" then local d = 1 + math.sin(angle)^2 x = (orbitRadius * math.cos(angle)) / d z = (orbitRadius * math.sin(angle) * math.cos(angle)) / d
                        elseif orbitStyle == "DNA Helix" then x, z = math.cos(angle) * orbitRadius, math.sin(angle) * orbitRadius y = bounceY + math.sin((t * orbitSpeed) + offset) * orbitRadius
                        elseif orbitStyle == "ATOM" then local ax = (math.pi / #orbitProps) * i x = math.cos(angle) * orbitRadius y = bounceY + math.sin(angle) * orbitRadius * math.cos(ax) z = math.sin(angle) * orbitRadius * math.sin(ax)
                        elseif orbitStyle == "Heart Beat" then local p = orbitRadius + (math.abs(math.sin(t * 6)) * 4) x, z = math.cos(angle) * p, math.sin(angle) * p
                        elseif orbitStyle == "Black Hole" then local s = orbitRadius * ((math.sin(t * orbitSpeed) + 1.5) / 2.5) x, z = math.cos(angle * 2) * s, math.sin(angle * 2) * s
                        elseif orbitStyle == "Galaxy Swirl" then x = math.cos(angle) * (orbitRadius + (i * 0.5)) z = math.sin(angle) * (orbitRadius + (i * 0.5))
                        elseif orbitStyle == "Meteor Shower" then x, z = math.cos(angle) * orbitRadius, math.sin(angle) * orbitRadius y = bounceY + ((t * 20 + i * 5) % 30) - 15
                        elseif orbitStyle == "Tornado" then local h = (i / #orbitProps) * 15 local r = orbitRadius * (h / 15) x, z = math.cos(angle) * r, math.sin(angle) * r y = bounceY + h - 7.5
                        elseif orbitStyle == "Pendulum Swing" then x = math.sin(t * orbitSpeed + offset) * orbitRadius y = bounceY - math.abs(math.cos(t * orbitSpeed + offset)) * (orbitRadius / 2)
                        elseif orbitStyle == "Quantum Jitter" then x = math.cos(angle) * orbitRadius + math.random(-2,2) y = bounceY + math.random(-2,2) z = math.sin(angle) * orbitRadius + math.random(-2,2)
                        elseif orbitStyle == "Infinity Loop 3D" then x = math.cos(angle) * orbitRadius y = bounceY + math.sin(angle * 2) * (orbitRadius / 2) z = math.sin(angle) * orbitRadius
                        elseif orbitStyle == "Pulsar Burst" then local b = (math.floor(t * 2) % 2 == 0) and orbitRadius or orbitRadius * 2 x, z = math.cos(angle) * b, math.sin(angle) * b
                        elseif orbitStyle == "Lotus Flower" then local r = orbitRadius * math.cos(5 * angle) x, z = math.cos(angle) * r, math.sin(angle) * r
                        elseif orbitStyle == "Zigzag Ring" then local zi = math.round(math.sin(angle * 10)) * 2 x, z = math.cos(angle) * (orbitRadius + zi), math.sin(angle) * (orbitRadius + zi)
                        elseif orbitStyle == "Saturn Ring" then x = math.cos(angle) * orbitRadius * 1.5 z = math.sin(angle) * orbitRadius * 0.5
                        end

                        local pos = root.CFrame * tilt * CFrame.new(x, y, z)
                        local rx = spinX and math.rad(t * 200) or 0
                        local ry = spinY and math.rad(t * 200) or 0
                        local rz = spinZ and math.rad(t * 200) or 0
                        
                        task.spawn(function() pcall(function() remote:InvokeServer(pos * CFrame.Angles(rx, ry, rz)) end) end)

                        local targetColor = nil
                        if colorMode == "Sync Rainbow" then targetColor = syncColor
                        elseif colorMode == "Individual Multi" then targetColor = Color3.fromHSV(((t + i) % 5) / 5, 1, 1)
                        elseif colorMode == "Hyper Strobe" then targetColor = (math.random(1, 2) == 1) and Color3.new(1,1,1) or Color3.new(0,0,0)
                        end

                        if targetColor and data.PropObj then
                            if fullPropColorEnabled then
                                for _, part in ipairs(data.PropObj:GetDescendants()) do
                                    if part:IsA("BasePart") then
                                        part.Color = targetColor
                                    elseif part:IsA("Frame") or part:IsA("ScrollingFrame") then
                                        part.BackgroundColor3 = targetColor
                                    elseif part:IsA("Decal") or part:IsA("Texture") then
                                        part.Color3 = targetColor
                                    end
                                end
                            else
                                if data.Part and data.Part:IsA("BasePart") then
                                    data.Part.Color = targetColor
                                end
                            end
                        end
                        
                    end
                end
            end
        end
    end
end)
