local function BuildMessageBubble(container, name, text, isMine)
    local wrapper = Instance.new("Frame", container)
    wrapper.Size = UDim2.new(1, 0, 0, 0) 
    wrapper.AutomaticSize = Enum.AutomaticSize.Y
    wrapper.BackgroundTransparency = 1

    local bubble = Instance.new("Frame", wrapper)
    bubble.BackgroundColor3 = isMine and Colors.MyBubble or Colors.OtherBubble
    bubble.AutomaticSize = Enum.AutomaticSize.XY
    Instance.new("UICorner", bubble).CornerRadius = UDim.new(0, 8)
    
    local pad = Instance.new("UIPadding", bubble)
    pad.PaddingTop = UDim.new(0,6); pad.PaddingBottom = UDim.new(0,6)
    pad.PaddingLeft = UDim.new(0,8); pad.PaddingRight = UDim.new(0,8)

    local bStroke = Instance.new("UIStroke", bubble)
    bStroke.Color = isMine and Colors.Accent or Color3.fromRGB(80, 80, 90)
    bStroke.Thickness = 1
    bStroke.Transparency = 0.3

    if isMine then
        bubble.AnchorPoint = Vector2.new(1, 0)
        bubble.Position = UDim2.new(1, 0, 0, 0)
    else
        bubble.AnchorPoint = Vector2.new(0, 0)
        bubble.Position = UDim2.new(0, 0, 0, 0)
    end

    local txt = Instance.new("TextLabel", bubble)
    txt.BackgroundTransparency = 1
    
    local nameHex = isMine and "#88ccff" or "#a0a0b0"
    txt.Text = "<font size='9' color='"..nameHex.."'><b>" .. name .. "</b></font>\n" .. text
    txt.RichText = true
    txt.Font = Enum.Font.Gotham
    txt.TextSize = 11
    txt.TextColor3 = Colors.Text
    txt.TextXAlignment = isMine and Enum.TextXAlignment.Right or Enum.TextXAlignment.Left
    txt.AutomaticSize = Enum.AutomaticSize.XY
    txt.TextWrapped = true
    
    local constraint = Instance.new("UISizeConstraint", txt)
    constraint.MaxSize = Vector2.new(230, 9999)

    -- 🔥 FIX: UIScale removes layout rendering bugs for incoming messages
    local bScale = Instance.new("UIScale", wrapper)
    bScale.Scale = 0
    TweenService:Create(bScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
    
    task.delay(0.1, function()
        container.CanvasPosition = Vector2.new(0, container.AbsoluteWindowSize.Y + 9999)
    end)
end

local function ProcessQueue()
    if getgenv().QUEUE_PROCESSING then return end
    getgenv().QUEUE_PROCESSING = true
    task.spawn(function()
        while #messageQueue > 0 do
            local msg = messageQueue[1]
            local res = reqFunc({UrlParams = DB_PATH .. ".json", Method = "POST", Body = HttpService:JSONEncode(msg)})
            if res.Success then
                table.remove(messageQueue, 1) 
            end
            task.wait(0.5)
        end
        getgenv().QUEUE_PROCESSING = false
    end)
end

local function SendMsg()
    local txt = ChatBox.Text
    if txt == "" then return end
    ChatBox.Text = ""

    if activeTab == "Server" then
        local enc = E2EE_Encrypt(txt, SERVER_E2EE_KEY)
        local payload = {
            senderId = myUserId,
            senderName = cleanMyName,
            text = enc,
            timestamp = os.time()
        }
        table.insert(messageQueue, payload)
        ProcessQueue()
        BuildMessageBubble(ServerScroll, cleanMyName, txt, true)
    elseif activeTab == "DM" and activeDmTarget then
        local dmKey = getDmConvoKey(myUserId, activeDmTarget) .. "_DM_SECURE"
        local enc = E2EE_Encrypt(txt, dmKey)
        local payload = {senderId = myUserId, senderName = cleanMyName, text = enc, timestamp = os.time()}
        task.spawn(function()
            pcall(reqFunc, {UrlParams = "global_dms/" .. activeDmTarget .. ".json", Method = "POST", Body = HttpService:JSONEncode(payload)})
        end)
        BuildMessageBubble(DMScroll, cleanMyName, txt, true)
    end
end
