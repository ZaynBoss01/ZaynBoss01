    loadDmHistory = function(targetUid)
        for _, c in ipairs(dmChatFrame:GetChildren()) do
            if c:IsA("Frame") then c:Destroy() end
        end
        local convoKey = getDmConvoKey(myUserId, targetUid)
        task.spawn(function()
            local res = reqFunc({Url = FIREBASE_URL .. "dm_history/" .. convoKey .. '.json?orderBy="$key"&limitToLast=50', Method = "GET"})
            if res.Success and res.Body ~= "null" then
                local data = HttpService:JSONDecode(res.Body)
                local currentTime = os.time()
                local threeDaysInSeconds = 259200
                local sortedKeys = {}
                for k, _ in pairs(data) do table.insert(sortedKeys, k) end
                table.sort(sortedKeys)
                for _, k in ipairs(sortedKeys) do
                    local msgData = data[k]
                    if msgData and msgData.timestamp then
                        if (currentTime - msgData.timestamp) > threeDaysInSeconds then
                            reqFunc({Url = FIREBASE_URL .. "dm_history/" .. convoKey .. "/" .. k .. ".json", Method = "DELETE"})
                        else
                            local senderName = msgData.senderName or "Unknown"
                            addMessageToChat(senderName, msgData.text, false, tonumber(msgData.senderId), "DM", k, targetUid)
                        end
                    end
                end
            end
            task.wait(0.15)
            local maxScroll = dmChatLayout.AbsoluteContentSize.Y - dmChatFrame.AbsoluteSize.Y + 20
            if maxScroll > 0 then dmChatFrame.CanvasPosition = Vector2.new(0, maxScroll) end
        end)
    end

