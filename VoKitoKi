local function reqFunc(options)
    local method = options.Method or "GET"
    local requestData = {
        Url = PROXY_URL,
        Method = "POST", 
        Headers = { 
            ["Content-Type"] = "application/json", 
            ["User-Agent"] = "Roblox/NexusChat",
            ["Cache-Control"] = "no-cache"
        },
        Body = HttpService:JSONEncode({
            secret_key = SECRET_KEY,
            method = method,
            path = options.UrlParams,
            body = options.Body,
            -- 🔥 CACHE BUSTER: Forces Mobile Executors to fetch NEW data every time!
            _executor_cache_buster = tostring(tick()) .. tostring(math.random(10000, 99999))
        })
    }
    
    local s, r = pcall(request_func, requestData)
    if s and r and r.Body and r.Body ~= "ACCESS_DENIED" and not string.match(r.Body, "^ERROR") then
        return {Success = true, Body = r.Body}
    end
    return {Success = false, Body = (r and r.Body) or "Request Failed"}
end

