    sendMsg = function(txt)
        txt = tostring(txt):gsub("^%s+", ""):gsub("%s+$", "")
        if txt == "" or isBlacklisted then return end

        if txt:lower() == "/help" then
            addMessageToChat("[SYSTEM]", "🌟 Z C H A T - COMMANDS 🌟\n\n💬 /tr [lang] [msg] - Translate\n• /setlang [lang] - Set default lang\n\n📱 /img [url] | /voice [id] | /snap [msg]\n• Hold YOUR message to Unsend / Translate!\n• Swipe bubble left/right to Reply!\n\n🎧 DJ: /djplay [yt_url] | /djstop\n• /djmute | /djunmute", true, nil, "Server")
            return
        end

        if txt:lower() == "/djmute" then isDjMuted = true; if currentDjSound then currentDjSound.Volume = 0 end; addMessageToChat("[SYSTEM]", "🔇 DJ muted locally. /djunmute to listen again.", true, nil, "Server"); return end
        if txt:lower() == "/djunmute" then isDjMuted = false; if currentDjSound then currentDjSound.Volume = 1 end; addMessageToChat("[SYSTEM]", "🔊 DJ unmuted.", true, nil, "Server"); return end

        if isOwner and txt:lower() == "/globalhelp" then
            table.insert(messageQueue, {text="["..SERVER_ID.."] [SERVER_ANN] SYSTEM: 🌟 Z CHAT GLOBAL ALERT 🌟 Type /help to see features!", timestamp=os.time()}); processQueue()
            addMessageToChat("[SYSTEM]", "✅ Global help broadcasted.", true, nil, "Server"); return
        end

        if txt:lower():sub(1,9) == "/setlang " then
            local code = txt:sub(10):match("^(%w+)")
            if code then saveLang(code:lower()); addMessageToChat("[SYSTEM]", "✅ Translation language: " .. myTargetLang:upper(), true, nil, "Server") end; return
        end

        if txt:lower():sub(1,4) == "/tr " then
            local lang, tmsg = txt:sub(5):match("^(%S+)%s+(.+)$")
            if lang and tmsg then addMessageToChat("[SYSTEM]", "Translating...", true, nil, "Server"); txt = translateText(tmsg, lang) end
        end

        if txt:lower():sub(1,5) == "/afk " then myAfkReason = txt:sub(6); addMessageToChat("[SYSTEM]", "You are now AFK: " .. myAfkReason, true, nil, "Server"); return
        elseif myAfkReason then myAfkReason = nil; addMessageToChat("[SYSTEM]", "Welcome back! AFK mode disabled.", true, nil, "Server") end

