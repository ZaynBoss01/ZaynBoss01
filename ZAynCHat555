    local function DownloadAndPlayYTAudio(vId, senderName)
        globalDjSequence = globalDjSequence + 1; local mySeq = globalDjSequence
        StopZaynDJ(); globalDjSequence = mySeq
        addMessageToChat("System", "💿 "..senderName.." is loading a track...", true, nil, "Server")
        task.spawn(function()
            if mySeq ~= globalDjSequence then return end
            local api = reqFunc({Url=API_URL..vId,Method="GET",Headers={["x-rapidapi-host"]=RAPID_API_HOST,["x-rapidapi-key"]=RAPID_API_KEY}})
            if mySeq ~= globalDjSequence then return end
            if not (api.Success and api.StatusCode == 200) then addMessageToChat("System","❌ DJ API Error!",true,nil,"Server"); return end
            local ok, d = pcall(function() return HttpService:JSONDecode(api.Body) end)
            if not ok or not d then addMessageToChat("System","❌ DJ: Parse error.",true,nil,"Server"); return end
            local st = d.status or d.msg or ""
            if st ~= "ok" and st ~= "success" then addMessageToChat("System","❌ DJ: "..tostring(st),true,nil,"Server"); return end
            local link, songTitle = d.link, d.title or "Unknown Track"
            if not link or link == "" then addMessageToChat("System","❌ DJ: No link!",true,nil,"Server"); return end
            if mySeq ~= globalDjSequence then return end
            addMessageToChat("System","📥 Downloading: "..songTitle:sub(1,40),true,nil,"Server")
            local ar = reqFunc({Url=link,Method="GET"})
            if mySeq ~= globalDjSequence then return end
            if not ar.Success then addMessageToChat("System","❌ DJ: Download failed!",true,nil,"Server"); return end
            if not writefile or not getcustomasset then addMessageToChat("System","❌ DJ: Executor write not supported!",true,nil,"Server"); return end
            local fn = "zayn_dj_"..vId.."_"..math.random(1000,9999)..".mp3"
            if not pcall(function() writefile(fn, ar.Body) end) then addMessageToChat("System","❌ DJ: File write failed!",true,nil,"Server"); return end
            local ok2, assetId = pcall(function() return getcustomasset(fn) end)
            if not ok2 or not assetId then addMessageToChat("System","❌ DJ: Asset load failed!",true,nil,"Server"); return end
            if mySeq ~= globalDjSequence then if delfile and isfile and isfile(fn) then pcall(function() delfile(fn) end) end; return end
            StopZaynDJ(); globalDjSequence = mySeq; currentDjFileName = fn
            local snd = Instance.new("Sound"); snd.Name="ZaynDJ_Audio"; snd.SoundId=assetId
            snd.Volume=isDjMuted and 0 or 1; snd.RollOffMaxDistance=0; snd.Parent=djFolder; snd:Play()
            currentDjSound = snd; if getgenv then getgenv().ZAYN_DJ_SOUND_REF = snd end
            addMusicBubble(songTitle, senderName)
            addMessageToChat("System","🎵 Now Playing: "..songTitle,true,nil,"Server")
            snd.Ended:Connect(function()
                if currentDjSound == snd then currentDjSound=nil; if getgenv then getgenv().ZAYN_DJ_SOUND_REF=nil end
                    removeMusicBubble(); addMessageToChat("System","🎵 Track ended.",true,nil,"Server") end
                pcall(function() snd:Destroy() end); if delfile then pcall(function() delfile(fn) end) end; currentDjFileName=nil
            end)
        end)
    end

