    -- sendMsg
    -- ================================================================= --
    sendMsg = function(txt)
        txt = tostring(txt):gsub("^%s+",""):gsub("%s+$","")
        if txt == "" or isBlacklisted then return end

        if txt:lower() == "/help" then
            addMessageToChat("[SYSTEM]","🌟 Z CHAT V49.2 COMMANDS\n/tr [lang] [msg] · /setlang [lang]\n/img [url] · /voice [id] · /snap [msg]\n/djplay [yt] · /djstop · /djmute · /djunmute\nSwipe ← → to Reply | Hold for menu",true,nil,"Server"); return
        end
        if txt:lower()=="/djmute" then isDjMuted=true; if currentDjSound then currentDjSound.Volume=0 end; addMessageToChat("[SYSTEM]","🔇 DJ muted.",true,nil,"Server"); return end
        if txt:lower()=="/djunmute" then isDjMuted=false; if currentDjSound then currentDjSound.Volume=1 end; addMessageToChat("[SYSTEM]","🔊 DJ unmuted.",true,nil,"Server"); return end
        if txt:lower():sub(1,9)=="/setlang " then
            local c=txt:sub(10):match("^(%w+)"); if c then saveLang(c:lower()); addMessageToChat("[SYSTEM]","✅ Lang: "..myTargetLang:upper(),true,nil,"Server") end; return
        end
        if txt:lower():sub(1,4)=="/tr " then
            local lang, tmsg = txt:sub(5):match("^(%S+)%s+(.+)$")
            if lang and tmsg then addMessageToChat("[SYSTEM]","Translating...",true,nil,"Server"); txt=translateText(tmsg,lang) end
        end
        if txt:lower():sub(1,5)=="/afk " then
            myAfkReason=txt:sub(6); addMessageToChat("[SYSTEM]","💤 AFK: "..myAfkReason,true,nil,"Server"); return
        elseif myAfkReason then myAfkReason=nil; addMessageToChat("[SYSTEM]","👋 AFK off.",true,nil,"Server") end
        if txt:lower():sub(1,5)=="/img " then
            local u=txt:sub(6):gsub("%s+",""); if u:find("http") then txt="[PHOTO:"..u.."]" else return end
        end
        if txt:lower():sub(1,7)=="/voice " then
            local a=txt:sub(8):gsub("%s+",""); if tonumber(a) then txt="[VOICE:"..a.."]" else return end
        end
        if txt:lower():sub(1,6)=="/snap " then txt="[SNAP] "..txt:sub(7) end

        if isOwner then
            if txt:lower()=="/admincmds" then
                addMessageToChat("[SYSTEM]","👑 ADMIN: /gban /ungban /say /title /removetitle /clearalltitles /target /untarget /djgrant /djrevoke /mutechat /unmutechat",true,nil,"Server"); return
            end
            if txt:lower():sub(1,9)=="/djgrant " then
                local tU=txt:sub(10):match("^%s*(%S+)"); if tU then
                    local tgt=nil
                    for u,d in pairs(activeScriptUsers) do if d.name:lower()==tU:lower() or d.displayName:lower()==tU:lower() then tgt=u; break end end
                    if not tgt then for _,p in ipairs(Players:GetPlayers()) do if p.Name:lower()==tU:lower() or p.DisplayName:lower()==tU:lower() then tgt=tostring(p.UserId); break end end end
                    if tgt then
                        pcall(function() reqFunc({Url=FIREBASE_URL.."dj_permissions/"..tgt..".json",Method="PUT",Body="true"}) end)
                        table.insert(messageQueue,{text="[ZAYN_DJ_GRANT:"..tgt.."]",timestamp=os.time()}); processQueue()
                        addMessageToChat("System","✅ DJ granted to "..tU,true,nil,"Server")
                    end
                end; return
            end
            if txt:lower():sub(1,10)=="/djrevoke " then
                local tU=txt:sub(11):match("^%s*(%S+)"); if tU then
                    local tgt=nil
                    for u,d in pairs(activeScriptUsers) do if d.name:lower()==tU:lower() or d.displayName:lower()==tU:lower() then tgt=u; break end end
                    if tgt then
                        pcall(function() reqFunc({Url=FIREBASE_URL.."dj_permissions/"..tgt..".json",Method="DELETE"}) end)
                        table.insert(messageQueue,{text="[ZAYN_DJ_REVOKE:"..tgt.."]",timestamp=os.time()}); processQueue()
                        addMessageToChat("System","❌ DJ revoked from "..tU,true,nil,"Server")
                    end
                end; return
            end
            if txt:lower():sub(1,7)=="/title " then
                local tU,tC,tT=txt:sub(8):match("^(%S+)%s+(%S+)%s+(.+)$")
                if tU and tT then
                    local tgt=nil
                    for u,d in pairs(activeScriptUsers) do if d.name:lower()==tU:lower() or d.displayName:lower()==tU:lower() then tgt=u; break end end
                    if not tgt then for _,p in ipairs(Players:GetPlayers()) do if p.Name:lower()==tU:lower() or p.DisplayName:lower()==tU:lower() then tgt=tostring(p.UserId); break end end end
                    if not tgt and tonumber(tU) then tgt=tU end
                    if tgt then
                        reqFunc({Url=FIREBASE_URL..TITLES_DB_PATH..tgt..".json",Method="PUT",Body=HttpService:JSONEncode({text=tT,color=tC,expire=0,sig=genTitleSig(tgt,tT,tC)})})
                        table.insert(messageQueue,{text="[ZAYN_TITLE_SYNC] SET::"..tgt.."::"..tC.."::"..tT.."::0",timestamp=os.time()}); processQueue()
                        addMessageToChat("System","✅ Title '"..tT.."' → "..tU,true,nil,"Server")
                    end
                end; return
            end
            if txt:lower():sub(1,13)=="/removetitle " then
                local tU=txt:sub(14):match("^%s*(%S+)"); if tU then
                    local tgt=nil
                    for u,d in pairs(activeScriptUsers) do if d.name:lower()==tU:lower() or d.displayName:lower()==tU:lower() then tgt=u; break end end
                    if not tgt then for _,p in ipairs(Players:GetPlayers()) do if p.Name:lower()==tU:lower() or p.DisplayName:lower()==tU:lower() then tgt=tostring(p.UserId); break end end end
                    if not tgt and tonumber(tU) then tgt=tU end
                    if tgt then
                        reqFunc({Url=FIREBASE_URL..TITLES_DB_PATH..tgt..".json",Method="DELETE"})
                        table.insert(messageQueue,{text="[ZAYN_TITLE_SYNC] REMOVE::"..tgt,timestamp=os.time()}); processQueue()
                        addMessageToChat("System","🗑 Title removed from "..tU,true,nil,"Server")
                    end
                end; return
            end
            if txt:lower()=="/clearalltitles" then
                reqFunc({Url=FIREBASE_URL..TITLES_DB_PATH..".json",Method="DELETE"})
                table.insert(messageQueue,{text="[ZAYN_TITLE_SYNC] CLEARALL",timestamp=os.time()}); processQueue()
                addMessageToChat("System","🧹 All titles cleared.",true,nil,"Server"); return
            end
            if txt:lower():sub(1,6)=="/gban " then
                local t=txt:sub(7):gsub("%s+",""); local tId=nil
                for u,d in pairs(activeScriptUsers) do if d.name:lower()==t:lower() or d.displayName:lower()==t:lower() then tId=u; break end end
                if tId then
                    reqFunc({Url=FIREBASE_URL..BLACKLIST_DB_PATH..tId..".json",Method="PUT",Body=HttpService:JSONEncode(true)})
                    table.insert(messageQueue,{text="["..SERVER_ID.."] [GBAN] "..tId.." ||"..myUserId.."_"..SECURE_AUTH_KEY,timestamp=os.time()}); processQueue()
                    addMessageToChat("[SYSTEM]","🔨 Banned: "..t,true,nil,"Server")
                end; return
            end
            if txt:lower():sub(1,8)=="/ungban " then
                local t=txt:sub(9):gsub("%s+",""); local tId=nil
                for u,d in pairs(activeScriptUsers) do if d.name:lower()==t:lower() or d.displayName:lower()==t:lower() then tId=u; break end end
                if tId then reqFunc({Url=FIREBASE_URL..BLACKLIST_DB_PATH..tId..".json",Method="DELETE"}); addMessageToChat("[SYSTEM]","✅ Unbanned: "..t,true,nil,"Server") end; return
            end
            if txt:lower()=="/mutechat" then
                table.insert(messageQueue,{text="["..SERVER_ID.."] [CHAT_MUTE] true ||"..myUserId.."_"..SECURE_AUTH_KEY,timestamp=os.time()}); processQueue(); return
            end
            if txt:lower()=="/unmutechat" then
                table.insert(messageQueue,{text="["..SERVER_ID.."] [CHAT_MUTE] false ||"..myUserId.."_"..SECURE_AUTH_KEY,timestamp=os.time()}); processQueue(); return
            end
            if txt:sub(1,5)=="/say " then
                table.insert(messageQueue,{text="["..SERVER_ID.."] [SERVER_ANN] SYSTEM: "..txt:sub(6),timestamp=os.time()}); processQueue(); return
            end
            if txt:lower():sub(1,8)=="/target " then
                table.insert(messageQueue,{text="[TARGET_MARK] "..txt:sub(9).." ||",timestamp=os.time()}); processQueue(); return
            end
            if txt:lower()=="/untarget" then
                table.insert(messageQueue,{text="[TARGET_REMOVE] ||",timestamp=os.time()}); processQueue(); return
            end
        end

        if hasDjPerm(myUserId) then
            if txt:lower():sub(1,8)=="/djplay " then
                local vId=GetVideoID(txt:sub(9):gsub("%s+",""))
                if vId and #vId>5 then
                    table.insert(messageQueue,{text="[ZAYN_DJ_PLAY:"..vId.."] ||"..myUserId,timestamp=os.time()}); processQueue()
                else addMessageToChat("System","❌ Invalid YouTube link!",true,nil,"Server") end; return
            end
            if txt:lower()=="/djstop" then
                table.insert(messageQueue,{text="[ZAYN_DJ_STOP] ||"..myUserId,timestamp=os.time()}); processQueue(); return
            end
        elseif txt:lower():sub(1,8)=="/djplay " or txt:lower()=="/djstop" then
            addMessageToChat("System","❌ No DJ permission!",true,nil,"Server"); return
        end

        if serverReplyContext and not txt:find("%[STICKER:") and not txt:find("%[PHOTO:") and not txt:find("%[VOICE:") then
            txt="↪️ [Replying to "..serverReplyContext.."]\n"..txt; updateServerReplyState(nil,nil)
        end

        local ts = os.time()
        local out = cleanMyName..": "..txt.." ||"..myUserId.."::"..genMsgHash(myUserId,txt,ts).."::"..ts
        task.spawn(function()
            local s,r=pcall(function()
                return reqFunc({Url=FIREBASE_URL..DB_PATH..".json",Method="POST",Body=HttpService:JSONEncode({text=out,timestamp=ts})})
            end)
            if s and r and r.Success and r.Body then
                pcall(function()
                    local res=HttpService:JSONDecode(r.Body)
                    if res and res.name then
                        for _,c in ipairs(chatFrame:GetChildren()) do
                            if c:IsA("Frame") and c:GetAttribute("FBKey")==nil and c.LayoutOrder==messageCount then
                                c:SetAttribute("FBKey", res.name)
                            end
                        end
                    end
                end)
            end
        end)
        pcall(function() addMessageToChat(cleanMyName,txt,false,myUserId,"Server") end)
        createBubble(cleanMyName, txt, LocalPlayer)
    end

