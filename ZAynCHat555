    local function GetVideoID(url)
        local id = url:match("v=([%w_-]+)")
        if not id then id = url:match("youtu%.be/([%w_-]+)") end
        if not id then id = url:match("youtube%.com/shorts/([%w_-]+)") end
        return id or url
    end

    local function DownloadAndPlayYTAudio(vId, senderName)
        globalDjSequence = globalDjSequence + 1
        local mySeq = globalDjSequence
        StopZaynDJ(); globalDjSequence = mySeq
        addMessageToChat("System", "💿 " .. senderName .. " is loading a track...", true, nil, "Server")
        task.spawn(function()
            if mySeq ~= globalDjSequence then return end
            local apiResponse = reqFunc({Url = API_URL .. vId, Method = "GET", Headers = {["x-rapidapi-host"]=RAPID_API_HOST,["x-rapidapi-key"]=RAPID_API_KEY}})
            if mySeq ~= globalDjSequence then return end
            if not (apiResponse.Success and apiResponse.StatusCode == 200) then
                addMessageToChat("System", "❌ DJ API Error!", true, nil, "Server"); return
            end
            local s, data = pcall(function() return HttpService:JSONDecode(apiResponse.Body) end)
            if not s or not data then addMessageToChat("System", "❌ DJ: Parse error.", true, nil, "Server"); return end
            local apiStatus = data.status or data.msg or ""
            if apiStatus ~= "ok" and apiStatus ~= "success" then
                addMessageToChat("System", "❌ DJ: " .. tostring(apiStatus), true, nil, "Server"); return
            end
            local directLink = data.link; local songTitle = data.title or "Unknown Track"
            if not directLink or directLink == "" then addMessageToChat("System", "❌ DJ: No link!", true, nil, "Server"); return end
            if mySeq ~= globalDjSequence then return end
            addMessageToChat("System", "📥 Downloading: " .. songTitle:sub(1,40), true, nil, "Server")
            local audioRes = reqFunc({Url = directLink, Method = "GET"})
            if mySeq ~= globalDjSequence then return end
            if not audioRes.Success then addMessageToChat("System", "❌ DJ: Download failed!", true, nil, "Server"); return end
            if not writefile or not getcustomasset then addMessageToChat("System", "❌ DJ: File write not supported!", true, nil, "Server"); return end
            local fileName = "zayn_dj_" .. vId .. "_" .. math.random(1000,9999) .. ".mp3"
            local writeOk = pcall(function() writefile(fileName, audioRes.Body) end)
            if not writeOk then addMessageToChat("System", "❌ DJ: File write failed!", true, nil, "Server"); return end
            local success, assetId = pcall(function() return getcustomasset(fileName) end)
            if not success or not assetId then addMessageToChat("System", "❌ DJ: Asset load failed!", true, nil, "Server"); return end
            if mySeq ~= globalDjSequence then if delfile and isfile and isfile(fileName) then pcall(function() delfile(fileName) end) end; return end
            StopZaynDJ(); globalDjSequence = mySeq; currentDjFileName = fileName
            local newSound = Instance.new("Sound")
            newSound.Name = "ZaynDJ_Audio"; newSound.SoundId = assetId
            newSound.Volume = isDjMuted and 0 or 1; newSound.RollOffMaxDistance = 0
            newSound.Parent = djFolder; newSound:Play()
            currentDjSound = newSound
            if getgenv then getgenv().ZAYN_DJ_SOUND_REF = newSound end
            addMusicBubble(songTitle, senderName)
            addMessageToChat("System", "🎵 Now Playing: " .. songTitle, true, nil, "Server")
            newSound.Ended:Connect(function()
                if currentDjSound == newSound then currentDjSound = nil; if getgenv then getgenv().ZAYN_DJ_SOUND_REF = nil end; removeMusicBubble(); addMessageToChat("System", "🎵 Track ended.", true, nil, "Server") end
                pcall(function() newSound:Destroy() end); if delfile then pcall(function() delfile(fileName) end) end; currentDjFileName = nil
            end)
        end)
    end

