    -- ╔══════════════════════════════════════════════════════════╗
    -- ║           addMessageToChat  — PREMIUM VERSION            ║
    -- ║  Obsidian glass bubbles + reply shadow bubble            ║
    -- ╚══════════════════════════════════════════════════════════╝
    -- ================================================================= --
    addMessageToChat = function(name, message, isSystem, userId, chatType, fbKey, convoId)
        pcall(function()
            messageCount = messageCount + 1
            local targetFrame  = (chatType=="DM") and dmChatFrame or chatFrame
            local targetLayout = (chatType=="DM") and dmChatLayout or chatLayout

            local INNER_W       = 360
            local MAX_BUBBLE    = math.floor(INNER_W * 0.74)
            local MAX_IMG       = math.min(MAX_BUBBLE - 18, 155)

            local master = Instance.new("Frame", targetFrame)
            master.Size = UDim2.new(1, 0, 0, 20)
            master.AutomaticSize = Enum.AutomaticSize.Y
            master.BackgroundTransparency = 1
            master.LayoutOrder = messageCount
            master.ClipsDescendants = false
            if fbKey and fbKey ~= "" then master:SetAttribute("FBKey", fbKey) end

            local cleanName = name:gsub("^%[[^%]]+%]%s+",""):gsub("^[👑💎]%s+",""):gsub("%[.-%]%s*","")
            local cleanMsg  = tostring(message)
            local isMyMsg   = (tostring(userId) == myUserId)

            if chatType=="DM" then
                local cid = convoId or userId
                if cid then
                    master:SetAttribute("ConvoId", tostring(cid))
                    if activeDmUserId and tostring(cid) ~= tostring(activeDmUserId) then master.Visible = false end
                end
            end

            if userId and not isSystem and activeScriptUsers[tostring(userId)] then
                cleanName = activeScriptUsers[tostring(userId)].displayName
            elseif isMyMsg then cleanName = cleanMyName end

            -- ── System message ────────────────────────────────────
            if isSystem then
                local sysBg = Instance.new("Frame", master)
                sysBg.Size=UDim2.new(1,0,0,0); sysBg.AutomaticSize=Enum.AutomaticSize.Y
                sysBg.BackgroundColor3=Colors.BG2; sysBg.BackgroundTransparency=0.4; sysBg.BorderSizePixel=0
                makeCorner(sysBg, 8)
                -- Left accent stripe
                local stripe = Instance.new("Frame", sysBg); stripe.Size=UDim2.new(0,2,1,-6); stripe.Position=UDim2.new(0,4,0,3)
                stripe.BackgroundColor3=Colors.Primary; stripe.BorderSizePixel=0; makeCorner(stripe,2)
                task.spawn(function()
                    while stripe and stripe.Parent do
                        local t=(math.sin(tick()*1.8)+1)/2; pcall(function() stripe.BackgroundColor3=Colors.Primary:Lerp(Colors.Accent,t) end); task.wait(0.05)
                    end
                end)
                local pad=Instance.new("UIPadding",sysBg); pad.PaddingLeft=UDim.new(0,12); pad.PaddingRight=UDim.new(0,8); pad.PaddingTop=UDim.new(0,4); pad.PaddingBottom=UDim.new(0,4)
                local lbl=Instance.new("TextLabel",sysBg)
                lbl.Size=UDim2.new(1,0,0,0); lbl.AutomaticSize=Enum.AutomaticSize.Y
                lbl.BackgroundTransparency=1; lbl.Font=Enum.Font.Gotham; lbl.TextSize=11
                lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.TextWrapped=true; lbl.TextColor3=Colors.Yellow; lbl.Text=""
                local sc=Instance.new("UISizeConstraint",lbl); sc.MaxSize=Vector2.new(INNER_W-30,99999)
                task.spawn(function()
                    local full="⚡ "..cleanMsg
                    for i=1,#full do if not lbl.Parent then break end; lbl.Text=full:sub(1,i); task.wait(0.011) end
                end); return
            end

            local color = (chatType=="DM") and (isMyMsg and Colors.Cyan or Colors.Pink)
                or Color3.fromHSV((string.byte(cleanName,1)*14%360)/360, 0.55, 1)
            local isMentioned = false
            local lm = string.lower(cleanMsg)
            if (string.find(lm,"@"..string.lower(cleanMyName),1,true) or string.find(lm,"@"..string.lower(myUser),1,true)) and not isMyMsg then
                isMentioned = true
            end
            local isSnap = cleanMsg:match("^%[SNAP%]%s*(.*)")
            if isSnap then cleanMsg = "🔥 "..isSnap end
            local titleData = nil
            if userId then titleData = getPlayerTitle(userId) end
            local replyCtx, replyRest = cleanMsg:match("^↪️ %[Replying to (.-)%]\n(.*)")
            if replyCtx then cleanMsg = replyRest end

            local masterLayout = Instance.new("UIListLayout", master)
            masterLayout.FillDirection = Enum.FillDirection.Vertical; masterLayout.Padding = UDim.new(0,3)

            -- ╔═══════════════════════════════════════════════════╗
            -- ║   REPLY SHADOW BUBBLE — glass card with accent    ║
            -- ╚═══════════════════════════════════════════════════╝
            if replyCtx then
                local rFrame = Instance.new("Frame", master)
                rFrame.Size = UDim2.new(1, 0, 0, 0); rFrame.AutomaticSize = Enum.AutomaticSize.Y
                rFrame.BackgroundColor3 = Colors.BG3; rFrame.BackgroundTransparency = 0.2
                rFrame.BorderSizePixel = 0; rFrame.LayoutOrder = 1
                makeCorner(rFrame, 8)
                -- Glowing left bar
                local rBar = Instance.new("Frame", rFrame)
                rBar.Size = UDim2.new(0, 3, 1, -8); rBar.Position = UDim2.new(0, 5, 0, 4)
                rBar.BackgroundColor3 = color; rBar.BorderSizePixel = 0; makeCorner(rBar, 2)
                -- Subtle stroke
                local rStroke = makeStroke(rFrame, color, 1, 0.5)
                -- Reply icon + text
                local rPad = Instance.new("UIPadding", rFrame)
                rPad.PaddingLeft = UDim.new(0, 14); rPad.PaddingRight = UDim.new(0, 8)
                rPad.PaddingTop = UDim.new(0, 4); rPad.PaddingBottom = UDim.new(0, 4)
                local rRow = Instance.new("Frame", rFrame)
                rRow.Size = UDim2.new(1,0,0,0); rRow.AutomaticSize = Enum.AutomaticSize.Y; rRow.BackgroundTransparency = 1
                local rRL = Instance.new("UIListLayout", rRow)
                rRL.FillDirection = Enum.FillDirection.Horizontal; rRL.Padding = UDim.new(0,4)
                local rIcon = Instance.new("TextLabel", rRow)
                rIcon.Size=UDim2.new(0,14,0,14); rIcon.Text="↩"; rIcon.Font=Enum.Font.GothamBold; rIcon.TextSize=11
                rIcon.TextColor3=color; rIcon.BackgroundTransparency=1; rIcon.LayoutOrder=1
                local rLbl = Instance.new("TextLabel", rRow)
                rLbl.Size=UDim2.new(0,0,0,0); rLbl.AutomaticSize=Enum.AutomaticSize.XY
                rLbl.Text=replyCtx; rLbl.Font=Enum.Font.Gotham; rLbl.TextSize=10
                rLbl.TextColor3=Colors.TextDim; rLbl.BackgroundTransparency=1; rLbl.TextWrapped=true
                rLbl.TextXAlignment=Enum.TextXAlignment.Left; rLbl.LayoutOrder=2
                local rCon=Instance.new("UISizeConstraint",rLbl); rCon.MaxSize=Vector2.new(MAX_BUBBLE-30,99999)
            end

            -- Row frame
            local rowFrame = Instance.new("Frame", master)
            rowFrame.BackgroundTransparency = 1; rowFrame.AutomaticSize = Enum.AutomaticSize.XY
            rowFrame.Size = UDim2.new(1,0,0,0); rowFrame.LayoutOrder = 2; rowFrame.ClipsDescendants = false
            local rowL = Instance.new("UIListLayout", rowFrame)
            rowL.FillDirection = Enum.FillDirection.Horizontal; rowL.Padding = UDim.new(0,7)
            rowL.VerticalAlignment = Enum.VerticalAlignment.Top; rowL.SortOrder = Enum.SortOrder.LayoutOrder
            local isRight = (isMyMsg and chatType=="DM")
            rowL.HorizontalAlignment = isRight and Enum.HorizontalAlignment.Right or Enum.HorizontalAlignment.Left

            local dpOrder = isRight and 2 or 1; local bblOrder = isRight and 1 or 2
            local uidStr = tostring(userId)

            -- Avatar
            local av = Instance.new("ImageButton", rowFrame)
            av.Size=UDim2.new(0,28,0,28); av.BackgroundTransparency=1; av.ScaleType=Enum.ScaleType.Crop
            av.LayoutOrder=dpOrder; makeCorner(av, 14)
            local avStroke = makeStroke(av, isMyMsg and Colors.Cyan or color, 1.5, 0)
            if chatType=="DM" and not isMyMsg then avStroke.Color=Colors.Pink end
            av.MouseButton1Click:Connect(function()
                if userId and tostring(userId) ~= myUserId then openMiniProfile(tostring(userId), cleanName, titleData) end
            end)
            local cdp = customProfiles[uidStr] and customProfiles[uidStr].dp
            if cdp and cdp:find("http") then
                task.spawn(function()
                    if _rawReq and writefile and getcustomasset then
                        local s,r=pcall(_rawReq,{Url=cdp,Method="GET"})
                        if s and r.StatusCode==200 then local fn="z_dp_"..uidStr..".png"; writefile(fn,r.Body); av.Image=getcustomasset(fn)
                        else av.Image="rbxthumb://type=AvatarHeadShot&id="..uidStr.."&w=150&h=150" end
                    end
                end)
            else av.Image="rbxthumb://type=AvatarHeadShot&id="..uidStr.."&w=150&h=150" end

            -- ── BUBBLE — Obsidian glass ────────────────────────────
            local bubble = Instance.new("Frame", rowFrame)
            bubble.AutomaticSize = Enum.AutomaticSize.XY
            bubble.BackgroundColor3 = isMyMsg and Colors.MyBubble or Colors.OtherBubble
            bubble.BackgroundTransparency = 0.05
            bubble.BorderSizePixel = 0; bubble.Size = UDim2.new(0,0,0,0); bubble.LayoutOrder = bblOrder
            makeCorner(bubble, 13)
            -- Size constraint
            local bCon = Instance.new("UISizeConstraint", bubble); bCon.MaxSize = Vector2.new(MAX_BUBBLE, 99999)
            -- Stroke
            local bStroke = makeStroke(bubble, avStroke.Color, 1, 0.55)
            -- Glass highlight strip at top
            local glassHighlight = Instance.new("Frame", bubble)
            glassHighlight.Size=UDim2.new(1,-16,0,1); glassHighlight.Position=UDim2.new(0,8,0,2)
            glassHighlight.BackgroundColor3=Color3.fromRGB(255,255,255); glassHighlight.BackgroundTransparency=0.82; glassHighlight.BorderSizePixel=0
            makeCorner(glassHighlight,1)
            -- Padding
            local bPad=Instance.new("UIPadding",bubble)
            bPad.PaddingLeft=UDim.new(0,9); bPad.PaddingRight=UDim.new(0,9)
            bPad.PaddingTop=UDim.new(0,6); bPad.PaddingBottom=UDim.new(0,6)
            local bInnerL=Instance.new("UIListLayout",bubble)
            bInnerL.FillDirection=Enum.FillDirection.Horizontal; bInnerL.Padding=UDim.new(0,4)
            bInnerL.VerticalAlignment=Enum.VerticalAlignment.Top; bInnerL.SortOrder=Enum.SortOrder.LayoutOrder; bInnerL.Wraps=true

            local ord = 0
            if titleData then
                local tL = createRGBTitle(bubble, titleData); tL.LayoutOrder = ord+1; ord = ord+1
            end

            local nameBtn = Instance.new("TextButton", bubble)
            nameBtn.BackgroundTransparency=1; nameBtn.Text=cleanName..":"
            nameBtn.Font=Enum.Font.GothamBlack; nameBtn.Size=UDim2.new(0,0,0,15)
            nameBtn.TextSize=12; nameBtn.TextColor3=color; nameBtn.AutomaticSize=Enum.AutomaticSize.X
            nameBtn.LayoutOrder=ord+1; nameBtn.TextTruncate=Enum.TextTruncate.AtEnd; nameBtn.TextYAlignment=Enum.TextYAlignment.Top
            local nameCon=Instance.new("UISizeConstraint",nameBtn); nameCon.MaxSize=Vector2.new(MAX_BUBBLE-22,15)
            nameBtn.MouseButton1Click:Connect(function()
                if userId and tostring(userId)~=myUserId then openMiniProfile(tostring(userId),cleanName,titleData) end
            end)
            ord = ord+1

            local stickId = cleanMsg:match("^%[STICKER:(%d+)%]%s*$")
            local photoUrl = cleanMsg:match("^%[PHOTO:(.-)%]%s*$")
            local voiceId  = cleanMsg:match("^%[VOICE:(%d+)%]%s*$")
            local msgTextLabel

            if photoUrl then
                if tostring(userId)==myUserId then addPhotoToGallery(photoUrl, false) end
                local pI=Instance.new("ImageButton",bubble); pI.BackgroundTransparency=1
                pI.Size=UDim2.new(0,MAX_IMG,0,MAX_IMG); pI.ScaleType=Enum.ScaleType.Fit; pI.BorderSizePixel=0; pI.LayoutOrder=ord+1
                makeCorner(pI,10); Instance.new("UISizeConstraint",pI).MaxSize=Vector2.new(MAX_IMG,MAX_IMG)
                task.spawn(function()
                    if _rawReq and writefile and getcustomasset then
                        local s,r=pcall(_rawReq,{Url=photoUrl,Method="GET"})
                        if s and r.StatusCode==200 then local fn="z_"..math.random(1000,9999)..".png"; writefile(fn,r.Body); pI.Image=getcustomasset(fn) end
                    end
                end)
                pI.MouseButton1Click:Connect(function() openFullScreenPreview(pI.Image) end)
            elseif stickId then
                local sT="rbxthumb://type=Asset&id="..stickId.."&w=150&h=150"
                local sI=Instance.new("ImageButton",bubble); sI.BackgroundTransparency=1
                sI.Size=UDim2.new(0,74,0,74); sI.Image=sT; sI.LayoutOrder=ord+1; makeCorner(sI,10)
                Instance.new("UISizeConstraint",sI).MaxSize=Vector2.new(74,74)
                sI.MouseButton1Click:Connect(function() openFullScreenPreview(sT) end)
            elseif voiceId then
                if tostring(userId)==myUserId then addVoiceToSaved(voiceId, false) end
                local vF=Instance.new("Frame",bubble); vF.Size=UDim2.new(0,math.min(134,MAX_BUBBLE-22),0,30)
                vF.BackgroundColor3=Colors.BG2; vF.LayoutOrder=ord+1; makeCorner(vF,9); makeStroke(vF,Colors.Primary,1,0.3)
                Instance.new("UISizeConstraint",vF).MaxSize=Vector2.new(math.min(134,MAX_BUBBLE-22),30)
                local pB2=Instance.new("TextButton",vF); pB2.Size=UDim2.new(0,28,0,28); pB2.Text="▶"; pB2.BackgroundTransparency=1
                pB2.TextColor3=Colors.Accent; pB2.Font=Enum.Font.GothamBold; pB2.TextSize=14
                local vLb=Instance.new("TextLabel",vF); vLb.Size=UDim2.new(1,-36,1,0); vLb.Position=UDim2.new(0,34,0,0)
                vLb.Text="Audio"; vLb.BackgroundTransparency=1; vLb.TextColor3=Colors.Text; vLb.TextXAlignment=Enum.TextXAlignment.Left; vLb.Font=Enum.Font.Gotham; vLb.TextSize=11
                local au2=Instance.new("Sound",vF); au2.SoundId="rbxassetid://"..voiceId; au2.Volume=1; local ip2=false
                pB2.MouseButton1Click:Connect(function()
                    if ip2 then au2:Stop(); pB2.Text="▶"; ip2=false else au2:Play(); pB2.Text="⏸"; ip2=true end
                end)
                au2.Ended:Connect(function() pB2.Text="▶"; ip2=false end)
            else
                msgTextLabel = Instance.new("TextLabel", bubble)
                msgTextLabel.BackgroundTransparency=1; msgTextLabel.Text=tostring(cleanMsg)
                msgTextLabel.Font=isMentioned and Enum.Font.GothamBold or Enum.Font.Gotham
                msgTextLabel.TextColor3=isMentioned and Colors.Gold or Colors.Text
                msgTextLabel.Size=UDim2.new(0,0,0,0); msgTextLabel.TextSize=12
                msgTextLabel.AutomaticSize=Enum.AutomaticSize.XY; msgTextLabel.TextWrapped=true
                msgTextLabel.TextXAlignment=Enum.TextXAlignment.Left; msgTextLabel.TextYAlignment=Enum.TextYAlignment.Top
                msgTextLabel.LayoutOrder=ord+1
                local mc=Instance.new("UISizeConstraint",msgTextLabel); mc.MaxSize=Vector2.new(MAX_BUBBLE-20,99999)
                if isMentioned then
                    -- Animated gold glow
                    task.spawn(function()
                        while msgTextLabel and msgTextLabel.Parent do
                            local t=(math.sin(tick()*2)+1)/2
                            pcall(function() msgTextLabel.TextColor3=Colors.Gold:Lerp(Color3.fromRGB(255,245,180),t) end); task.wait(0.05)
                        end
                    end)
                    task.spawn(function()
                        local sfx=Instance.new("Sound"); sfx.SoundId="rbxassetid://4590662766"; sfx.Volume=1.5; sfx.Parent=UI_PARENT; sfx:Play(); task.wait(2); pcall(function() sfx:Destroy() end)
                    end)
                end
            end

            -- ── Swipe + Hold gestures ─────────────────────────────
            local function attachGestures()
                local ck2 = ""
                if chatType=="DM" and activeDmUserId then ck2 = getDmConvoKey(myUserId, activeDmUserId) end
                local storedKey = master:GetAttribute("FBKey") or fbKey or ""
                local tStart, isSwiping, hasMoved, isHolding, holdTimer = nil, false, false, false, nil
                local swOff = 0

                local function setBubbleX(tx)
                    local mx, res = 80, 0.6
                    local fx = math.abs(tx) <= mx and tx*res or mx*res*(tx>0 and 1 or -1)
                    swOff = fx; pcall(function() rowFrame.Position=UDim2.new(0,fx,0,0) end)
                end
                local function snapBack(overshoot)
                    if overshoot then
                        local d=swOff>0 and 1 or -1; safeTween(rowFrame,{Position=UDim2.new(0,d*18,0,0)},0.06,Enum.EasingStyle.Sine); task.wait(0.06)
                    end
                    safeTween(rowFrame,{Position=UDim2.new(0,0,0,0)},0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out); swOff=0
                end
                local function triggerReply()
                    local rt = isSnap and "[Snap 🔥]" or cleanMsg
                    if chatType=="DM" then updateDmReplyState(cleanName, rt) else updateServerReplyState(cleanName, rt) end
                    pcall(function() local sfx=Instance.new("Sound",UI_PARENT); sfx.SoundId="rbxassetid://6895088918"; sfx.Volume=0.5; sfx:Play(); task.wait(0.4); sfx:Destroy() end)
                end

                master.InputBegan:Connect(function(inp)
                    if inp.UserInputType~=Enum.UserInputType.MouseButton1 and inp.UserInputType~=Enum.UserInputType.Touch then return end
                    tStart=inp.Position; isSwiping=false; hasMoved=false; isHolding=true
                    if holdTimer then task.cancel(holdTimer) end
                    holdTimer = task.delay(0.45, function()
                        if isHolding and not hasMoved then
                            isHolding=false
                            pcall(function() local sfx=Instance.new("Sound",UI_PARENT); sfx.SoundId="rbxassetid://6895088918"; sfx.Volume=0.4; sfx:Play(); task.wait(0.3); sfx:Destroy() end)
                            for _, dx in ipairs({5,-5,3,-3,0}) do
                                if not rowFrame.Parent then break end
                                safeTween(rowFrame,{Position=UDim2.new(0,swOff+dx,0,0)},0.05); task.wait(0.05)
                            end
                            openMsgCtx(msgTextLabel, cleanMsg, cleanName, chatType, master, isMyMsg, storedKey, chatType, ck2)
                        end
                    end)
                end)
                master.InputChanged:Connect(function(inp)
                    if not tStart then return end
                    if inp.UserInputType~=Enum.UserInputType.MouseMovement and inp.UserInputType~=Enum.UserInputType.Touch then return end
                    local d=inp.Position-tStart
                    if d.Magnitude > 6 then hasMoved=true; isHolding=false end
                    if math.abs(d.X) > 10 and math.abs(d.X) > math.abs(d.Y)*1.3 then isSwiping=true; setBubbleX(d.X) end
                end)
                master.InputEnded:Connect(function(inp)
                    if inp.UserInputType~=Enum.UserInputType.MouseButton1 and inp.UserInputType~=Enum.UserInputType.Touch then return end
                    isHolding=false; if holdTimer then task.cancel(holdTimer); holdTimer=nil end
                    if tStart and isSwiping then
                        local d=inp.Position-tStart
                        if math.abs(d.X)>50 and math.abs(d.X)>math.abs(d.Y)*1.3 then triggerReply(); snapBack(true)
                        else snapBack(false) end
                    end
                    tStart=nil; isSwiping=false
                end)
            end
            attachGestures()

            if isSnap then
                task.delay(10, function()
                    if master and master.Parent then
                        for _, v in ipairs(master:GetDescendants()) do
                            if v:IsA("TextLabel") or v:IsA("TextButton") then pcall(function() safeTween(v,{TextTransparency=1},0.5) end)
                            elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then pcall(function() safeTween(v,{ImageTransparency=1},0.5) end) end
                        end
                        task.wait(0.5); pcall(function() master:Destroy() end)
                    end
                end)
            end

            task.spawn(function()
                task.wait(0.1)
                if not targetFrame or master.Visible==false then return end
                local near = targetFrame.CanvasPosition.Y >= (targetLayout.AbsoluteContentSize.Y - targetFrame.AbsoluteWindowSize.Y - 100)
                if near or isMyMsg then
                    local ms = targetLayout.AbsoluteContentSize.Y - targetFrame.AbsoluteSize.Y + 20
                    if ms > 0 then safeTween(targetFrame, {CanvasPosition=Vector2.new(0,ms)}, 0.18, Enum.EasingStyle.Sine) end
                end
                local msgs = {}
                for _, c in ipairs(targetFrame:GetChildren()) do if c:IsA("Frame") then table.insert(msgs,c) end end
                if #msgs > MAX_MESSAGES then
                    table.sort(msgs, function(a,b) return a.LayoutOrder < b.LayoutOrder end)
                    for i=1, #msgs-MAX_MESSAGES do pcall(function() msgs[i]:Destroy() end) end
                end
            end)
        end)
    end

    -- ================================================================= --
    -- QUEUE PROCESSOR
    -- ================================================================= --
    processQueue = function()
        if queueProcessing or not reqFunc then return end
        queueProcessing = true
        task.spawn(function()
            while #messageQueue > 0 do
                local md = messageQueue[1]
                local s, r = pcall(function()
                    return reqFunc({Url=FIREBASE_URL..DB_PATH..".json",Method="POST",Body=HttpService:JSONEncode(md)})
                end)
                if s and r and r.Success then table.remove(messageQueue,1) else task.wait(0.5) end
                task.wait()
            end
            queueProcessing = false
        end)
    end

