                table.insert(messageQueue, {text="["..SERVER_ID.."] [CHAT_MUTE] true ||"..myUserId.."_"..SECURE_AUTH_KEY, timestamp=os.time()})
                processQueue(); return
            end
            if txt:lower() == "/unmutechat" then
                table.insert(messageQueue, {text="["..SERVER_ID.."] [CHAT_MUTE] false ||"..myUserId.."_"..SECURE_AUTH_KEY, timestamp=os.time()})
                processQueue(); return
