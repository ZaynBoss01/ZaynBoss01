                                                        elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then pcall(function() safeTween(v, {ImageTransparency = 1}, 0.25) end) end
                                                    end
                                                    safeTween(child, {Size = UDim2.new(0, 0, 0, 0)}, 0.25)
                                                    task.delay(0.3, function() pcall(function() child:Destroy() end) end)
                                                    return true
                                                end
                                            end
                                        end
                                        return false
                                    end
                                    -- Search chatFrame first, then dmChatFrame
                                    if not tryDeleteFromFrame(chatFrame) then
                                        tryDeleteFromFrame(dmChatFrame)
                                    end
                                    task.spawn(function()
                                        pcall(function() reqFunc({Url = FIREBASE_URL .. DB_PATH .. "/" .. delKey .. ".json", Method = "DELETE"}) end)
                                    end)
                                end
                                continue
                            end

                            if mtext:find("%[ZAYN_DJ_GRANT:") then
                                local uid = mtext:match("%[ZAYN_DJ_GRANT:([%w_]+)%]")
                                if uid then djPermittedUsers[uid] = true; addMessageToChat("System", "🎧 DJ permission granted!", true, nil, "Server") end; continue
                            end
                            if mtext:find("%[ZAYN_DJ_REVOKE:") then
                                local uid = mtext:match("%[ZAYN_DJ_REVOKE:([%w_]+)%]")
                                if uid then djPermittedUsers[uid] = nil end; continue
                            end
                            if mtext:find("%[ZAYN_DJ_PLAY:") then
                                local ytId = mtext:match("%[ZAYN_DJ_PLAY:([%w_-]+)%]")
                                local senderUid = mtext:match("||([%w_]+)$")
                                if ytId and senderUid and hasDjPermission(senderUid) then
                                    local dn = activeScriptUsers[senderUid] and activeScriptUsers[senderUid].displayName or "A DJ"
                                    lastDjPlayFirebaseKey = key
                                    DownloadAndPlayYTAudio(ytId, dn)
                                elseif ytId and senderUid and not hasDjPermission(senderUid) then
                                    task.spawn(function() pcall(function() reqFunc({Url = FIREBASE_URL .. DB_PATH .. "/" .. key .. ".json", Method = "DELETE"}) end) end)
                                end; continue
                            end
                            if mtext:find("%[ZAYN_DJ_STOP%]") then
                                local senderUid = mtext:match("||([%w_]+)$")
                                if senderUid and hasDjPermission(senderUid) then
                                    local dn = activeScriptUsers[senderUid] and activeScriptUsers[senderUid].displayName or "A DJ"
                                    StopZaynDJ(); addMessageToChat("System", "🛑 " .. dn .. " stopped the music.", true, nil, "Server")
                                end; continue
                            end
                            if mtext:find("%[ZAYN_SYNC%]") then
                                local tStamp, tSig, syncUid = mtext:match("%[ZAYN_SYNC%] (%d+):(%d+)%s*||([%w_]+)")
                                if syncUid and tStamp and tSig then
                                    if math.abs(os.time() - tonumber(tStamp)) <= 120 and tSig == generateSignature("SYNC", syncUid, tStamp) then
                                        local sdn, sun = getStrictIdentity(syncUid)
                                        if not isFirstLoad and syncUid ~= myUserId then
                                            if not activeScriptUsers[syncUid] or not activeScriptUsers[syncUid].welcomed then
                                                addMessageToChat("System", "👋 " .. sdn .. " joined!", true, nil, "Server")
                                            end
                                        end
                                        if not activeScriptUsers[syncUid] then
                                            activeScriptUsers[syncUid] = {displayName = sdn, name = sun, lastSeen = os.time(), welcomed = true}
                                        else activeScriptUsers[syncUid].lastSeen = os.time(); activeScriptUsers[syncUid].welcomed = true end
                                    end
                                end; continue
                            end
                            if mtext:find("%[ZAYN_PROFILE_SYNC%]") then
                                local pUid = mtext:match("%[ZAYN_PROFILE_SYNC%] ([%w_]+)")
                                if pUid then
                                    task.spawn(function()
                                        local pRes = reqFunc({Url = FIREBASE_URL .. "profiles/" .. pUid .. ".json", Method = "GET"})
                                        if pRes.Success and pRes.Body ~= "null" then
                                            pcall(function() customProfiles[pUid] = HttpService:JSONDecode(pRes.Body) end)
                                        end
                                    end)
                                end; continue
                            end
                            if mtext:find("%[ZAYN_TITLE_SYNC%]") then
                                local cmd = mtext:match("%[ZAYN_TITLE_SYNC%] (%w+)")
                                if cmd == "SET" then
                                    local u, c, t, e = mtext:match("SET::([%w_]+)::(%S+)::(.-)::(%d+)")
                                    if u and t then _internalTitles[u] = {text = t, color = c, expire = tonumber(e)} end
                                elseif cmd == "REMOVE" then
                                    local u = mtext:match("REMOVE::([%w_]+)"); if u then _internalTitles[u] = nil end
                                elseif cmd == "CLEARALL" then _internalTitles = {} end; continue
                            end

                            if isFirstLoad then continue end
                            if mtext:find("%[SYSTEM%]") then
                                addMessageToChat("System", mtext:match("%[SYSTEM%]%s*:%s*(.*)"), true, nil, "Server"); continue
                            end

                            local sName, sMsg, sUID, cleanN = parseMessage(mtext)
                            if sName and sMsg and tostring(sUID) ~= myUserId then
                                if not activeScriptUsers[sUID] then
                                    activeScriptUsers[sUID] = {displayName = cleanN, name = cleanN, lastSeen = os.time(), welcomed = true}
                                else activeScriptUsers[sUID].lastSeen = os.time() end

                                if not spamTracker[sUID] then spamTracker[sUID] = {} end
                                table.insert(spamTracker[sUID], os.time())
                                if #spamTracker[sUID] > 4 then table.remove(spamTracker[sUID], 1) end
                                if #spamTracker[sUID] == 4 and (spamTracker[sUID][4] - spamTracker[sUID][1] <= 2) then
                                    addMessageToChat("System", "🔇 Auto-muted " .. cleanN .. " (spam).", true, nil, "Server")
                                    spamTracker[sUID] = {}; continue
                                end

                                if myAfkReason then
                                    if string.find(string.lower(sMsg), "@" .. string.lower(cleanMyName), 1, true) or
                                       string.find(string.lower(sMsg), "@" .. string.lower(myUser), 1, true) then
                                        if os.time() - lastAfkReply > 10 then
                                            lastAfkReply = os.time()
                                            task.spawn(function() task.wait(0.5); sendMsg("🤖 [Auto-Reply]: AFK - " .. myAfkReason) end)
                                        end
                                    end
                                end

                                addMessageToChat(cleanN, sMsg, false, tonumber(sUID), "Server", key)
                                showNotif(cleanN, sMsg, false, tonumber(sUID), "Server", nil)
                                local targetP = tonumber(sUID) and Players:GetPlayerByUserId(tonumber(sUID))
                                if targetP then createBubble(cleanN, sMsg, targetP) end
                            end
                        end
                    end
                end
                isFirstLoad = false
                for uid, d in pairs(activeScriptUsers) do
                    if uid ~= myUserId and (os.time() - (d.lastSeen or 0)) > 120 then activeScriptUsers[uid] = nil end
                end
            end)
            task.wait(1.5)
        end
    end)

    -- ================================================================= --
    -- WELCOME MESSAGES
    -- ================================================================= --
    task.spawn(function()
        task.wait(3.5)
        addMessageToChat("System", "👋 Welcome " .. cleanMyName .. " — Z Chat V49.2 Ultra Premium!", true, nil, "Server")
        task.wait(0.3); addMessageToChat("System", "🎨 Theme: " .. THEME_NAMES[currentThemeIndex] .. " — Click 🎨 to cycle 7 themes!", true, nil, "Server")
        task.wait(0.3); addMessageToChat("System", "↩️ Swipe ← → to reply | Hold to access context menu", true, nil, "Server")
        task.wait(0.3); addMessageToChat("System", "🎧 DJ: /djplay [yt_link] · /djstop · /djmute | Type /help for all commands", true, nil, "Server")
    end)

    -- ================================================================= --
    -- TOGGLE BUTTON + DRAG
    -- ================================================================= --
    local toggleBtn = Instance.new("TextButton", sg)
    toggleBtn.Size = UDim2.new(0, 50, 0, 50)
    toggleBtn.Position = UDim2.new(0.02, 0, 0.5, -25)
    toggleBtn.Text = "💬"
    toggleBtn.TextColor3 = Colors.Text; toggleBtn.Font = Enum.Font.GothamBold; toggleBtn.TextSize = 24
    toggleBtn.BackgroundColor3 = Colors.BG2; toggleBtn.BackgroundTransparency = 0.08; toggleBtn.ZIndex = 20
    toggleBtn.AnchorPoint = Vector2.new(0, 0.5); toggleBtn.BorderSizePixel = 0
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)
    local toggleStroke = Instance.new("UIStroke", toggleBtn); toggleStroke.Thickness = 1.5
    task.spawn(function()
        while toggleStroke and toggleStroke.Parent do
            toggleStroke.Color = Colors.Primary:Lerp(Colors.Secondary, (math.sin(tick() * 2) + 1) / 2)
            task.wait(0.05)
        end
    end)
    toggleBtn.MouseEnter:Connect(function() safeTween(toggleBtn, {Size = UDim2.new(0, 54, 0, 54)}, 0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out) end)
    toggleBtn.MouseLeave:Connect(function() safeTween(toggleBtn, {Size = UDim2.new(0, 50, 0, 50)}, 0.15) end)

    local function makeDraggable(frame, dragArea)
        local dragging, dragStart, startPos, dragConn = false, nil, nil, nil
        dragArea.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = input.Position; startPos = frame.Position
                if dragConn then dragConn:Disconnect() end
                dragConn = UserInputService.InputChanged:Connect(function(input2)
                    if dragging and (input2.UserInputType == Enum.UserInputType.MouseMovement or input2.UserInputType == Enum.UserInputType.Touch) then
                        local delta = input2.Position - dragStart
                        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                    end
                end)
            end
        end)
        UserInputService.InputEnded:Connect(function(input3)
            if input3.UserInputType == Enum.UserInputType.MouseButton1 or input3.UserInputType == Enum.UserInputType.Touch then
                dragging = false; if dragConn then dragConn:Disconnect() end
            end
        end)
    end

    makeDraggable(main, titleBar)
    makeDraggable(toggleBtn, toggleBtn)
    toggleBtn.MouseButton1Click:Connect(function() toggleMainUI(not isUiOpen) end)
end

startMainChat()
