    local processedIds = {}
    task.spawn(function()
        task.wait(2)
        local joinTs = os.time(); local joinSig = generateSignature("SYNC", myUserId, joinTs)
        table.insert(messageQueue, {text = "[ZAYN_SYNC] " .. joinTs .. ":" .. joinSig .. " ||" .. myUserId, timestamp = joinTs})
        processQueue()

