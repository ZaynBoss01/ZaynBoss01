        local mp2 = Instance.new("UIPadding", mf); mp2.PaddingTop=UDim.new(0,4); mp2.PaddingBottom=UDim.new(0,4)
        Instance.new("UIListLayout", mf).Padding = UDim.new(0,1)

        local function addItem(icon, lbl, clr, fn)
            local b = Instance.new("TextButton", mf)
            b.Size=UDim2.new(1,0,0,38); b.BackgroundTransparency=1
            b.Text=icon.."  "..lbl; b.TextColor3=clr or Colors.Text
            b.Font=Enum.Font.GothamBold; b.TextSize=12; b.TextXAlignment=Enum.TextXAlignment.Left
            local p=Instance.new("UIPadding",b); p.PaddingLeft=UDim.new(0,12)
            b.MouseEnter:Connect(function() b.BackgroundColor3=Colors.BG3; safeTween(b,{BackgroundTransparency=0.5},0.1) end)
            b.MouseLeave:Connect(function() safeTween(b,{BackgroundTransparency=1},0.1) end)
