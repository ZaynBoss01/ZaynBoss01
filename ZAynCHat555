    function sendMsg(txt)
        txt = tostring(txt):gsub("^%s+", ""):gsub("%s+$", "")
        if txt == "" or isBlacklisted then return end
        
        if txt:lower() == "/help" then
            local helpText = "🌟 ZAYN CHAT - COMMANDS & FEATURES 🌟\n\n" ..
            "💬 TRANSLATOR:\n" ..
            "• /tr [lang] [msg] : Translate your message and send it (e.g. /tr hi Hello)\n" ..
            "• /setlang [lang] : Set default target language (e.g. /setlang hi)\n" ..
            "• Click the 🌍 button next to any message to translate it instantly.\n\n" ..
            "📱 MEDIA & FUN:\n" ..
            "• /img [url] : Send an image link directly.\n" ..
            "• /voice [id] : Play a Roblox audio ID in the chat.\n" ..
            "• /snap [msg] : Send a self-destructing message (deletes after 10s).\n" ..
            "• Click 📷 to open the Media Box, or 🌸 for the Sticker Panel.\n\n" ..
            "⚙️ UTILITY:\n" ..
            "• /afk [reason] : Sets you away and auto-replies if someone tags you.\n" ..
            "• Swipe Right on any message to quickly reply to it!"
            addMessageToChat("[SYSTEM]", helpText, true, nil, "Server")
            return
        end

        if isOwner and txt:lower() == "/globalhelp" then
            local globalHelpText = "🌟 ZAYN CHAT GLOBAL ALERT 🌟\n\n" ..
            "Type /help in the chat box to see all our premium features!\n" ..
            "You can use /tr [lang] [message] to translate texts, /snap [message] for self-deleting messages, and click the 🌍 icon to translate incoming chat!"
            table.insert(messageQueue, {text="["..SERVER_ID.."] [SERVER_ANN] SYSTEM: "..globalHelpText, timestamp=os.time()})
            processQueue()
            addMessageToChat("[SYSTEM]", "✅ Global help broadcasted to the server.", true, nil, "Server")
            return
        end
        
        if txt:lower():sub(1,9) == "/setlang " then
            local code = txt:sub(10):match("^(%w+)")
