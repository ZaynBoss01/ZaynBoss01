                local tRes = reqFunc({Url = FIREBASE_URL .. TYPING_PATH .. ".json", Method = "GET"})
                if tRes.Success and tRes.Body ~= "null" then
                    local tData = HttpService:JSONDecode(tRes.Body); local tUsers = {}
                    for uid, d in pairs(tData) do
                        if tostring(uid) ~= myUserId and (os.time() - (d.ts or 0)) < 4 then table.insert(tUsers, d.n) end
                    end
                    typingLbl.Text = #tUsers > 0 and (table.concat(tUsers, ", ") .. (#tUsers > 1 and " are typing..." or " is typing...")) or ""
                else typingLbl.Text = "" end

                -- Messages
                local res = reqFunc({Url = FIREBASE_URL .. DB_PATH .. '.json?orderBy="$key"&limitToLast=20', Method = "GET"})
                if res.Success and res.Body and res.Body ~= "null" then
                    local data = HttpService:JSONDecode(res.Body)
                    for key, msgData in pairs(data) do
                        if not processedIds[key] then
                            processedIds[key] = true
                            local mtext = msgData.text

                            -- ================================================================= --
                            -- UNSEND RECEIVED — FIXED: search BOTH frames
                            -- ================================================================= --
                            if mtext:find("%[ZAYN_UNSEND%]") then
                                local delKey = mtext:match("%[ZAYN_UNSEND%] ([%w_-]+)")
                                if delKey then
                                    local function tryDeleteFromFrame(frame)
                                        for _, child in ipairs(frame:GetChildren()) do
                                            if child:IsA("Frame") then
                                                local storedKey = child:GetAttribute("FBKey")
                                                if storedKey and storedKey == delKey then
                                                    for _, v in ipairs(child:GetDescendants()) do
