        end)
        addItem("⊕", "Translate", Colors.Yellow, function()
            addMessageToChat("[SYSTEM]","🌐 Translating...",true,nil,"Server")
            task.spawn(function()
                local t = translateText(msgText, myTargetLang)
                addMessageToChat("[SYSTEM]","🌐 ["..myTargetLang:upper().."]: "..t,true,nil,"Server")
            end)
        end)

        if isMyMsg then
            addItem("✕", "Unsend", Colors.Pink, function()
                -- Remove from both frames
                local function rmFrame(frame)
                    for _, c in ipairs(frame:GetChildren()) do
                        if c:IsA("Frame") and c:GetAttribute("FBKey") == fbKey then
                            safeTween(c, {GroupTransparency=1}, 0.25)
                            task.delay(0.3, function() pcall(function() c:Destroy() end) end); return true
                        end
                    end; return false
                end
                if not rmFrame(chatFrame) then rmFrame(dmChatFrame) end
                if container and container.Parent then
                    safeTween(container,{GroupTransparency=1},0.25)
                    task.delay(0.3,function() pcall(function() container:Destroy() end) end)
                end
                if fbKey and fbKey ~= "" then
                    task.spawn(function()
                        if chatTypL=="DM" and dmConvoKey and dmConvoKey ~= "" then
                            pcall(function() reqFunc({Url=FIREBASE_URL.."dm_history/"..dmConvoKey.."/"..fbKey..".json",Method="DELETE"}) end)
                        else
                            table.insert(messageQueue,{text="[ZAYN_UNSEND] "..fbKey,timestamp=os.time()}); processQueue()
                            task.spawn(function() task.wait(0.3); pcall(function() reqFunc({Url=FIREBASE_URL..DB_PATH.."/"..fbKey..".json",Method="DELETE"}) end) end)
                        end
                    end)
                end
            end)
        end
    end

