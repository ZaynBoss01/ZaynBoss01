    -- ================================================================= --
    -- MAIN POLLING LOOP
    -- ================================================================= --
    local processedIds = {}
    task.spawn(function()
        task.wait(2)
        local jTs=os.time(); local jSig=genSig("SYNC",myUserId,jTs)
        table.insert(messageQueue,{text="[ZAYN_SYNC] "..jTs..":"..jSig.." ||"..myUserId,timestamp=jTs}); processQueue()

        while true do
            pcall(function()
                -- Typing
                local tR=reqFunc({Url=FIREBASE_URL..TYPING_PATH..".json",Method="GET"})
                if tR.Success and tR.Body ~= "null" then
                    local tD=HttpService:JSONDecode(tR.Body); local tu={}
                    for uid,d in pairs(tD) do if tostring(uid)~=myUserId and (os.time()-(d.ts or 0))<4 then table.insert(tu,d.n) end end
                    typingLbl.Text = #tu>0 and (table.concat(tu,", ")..(" "..(#tu>1 and "are" or "is").." typing...")) or ""
                else typingLbl.Text="" end

                -- Messages
                local r=reqFunc({Url=FIREBASE_URL..DB_PATH..'.json?orderBy="$key"&limitToLast=20',Method="GET"})
                if r.Success and r.Body and r.Body ~= "null" then
                    local data=HttpService:JSONDecode(r.Body)
                    for key, md in pairs(data) do
                        if not processedIds[key] then
                            processedIds[key]=true
                            local mt=md.text

                            if mt:find("%[ZAYN_UNSEND%]") then
                                local dk=mt:match("%[ZAYN_UNSEND%] ([%w_-]+)")
                                if dk then
                                    local function rmF(frame)
                                        for _,c in ipairs(frame:GetChildren()) do
                                            if c:IsA("Frame") and c:GetAttribute("FBKey")==dk then
                                                for _,v in ipairs(c:GetDescendants()) do
                                                    if v:IsA("TextLabel") or v:IsA("TextButton") then pcall(function() safeTween(v,{TextTransparency=1},0.25) end)
                                                    elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then pcall(function() safeTween(v,{ImageTransparency=1},0.25) end) end
                                                end
                                                safeTween(c,{Size=UDim2.new(0,0,0,0)},0.25)
                                                task.delay(0.3,function() pcall(function() c:Destroy() end) end); return true
                                            end
                                        end; return false
                                    end
                                    if not rmF(chatFrame) then rmF(dmChatFrame) end
                                    task.spawn(function() pcall(function() reqFunc({Url=FIREBASE_URL..DB_PATH.."/"..dk..".json",Method="DELETE"}) end) end)
                                end; continue
                            end
                            if mt:find("%[ZAYN_DJ_GRANT:") then
                                local uid=mt:match("%[ZAYN_DJ_GRANT:([%w_]+)%]")
                                if uid then djPermittedUsers[uid]=true; addMessageToChat("System","🎧 DJ permission granted!",true,nil,"Server") end; continue
                            end
                            if mt:find("%[ZAYN_DJ_REVOKE:") then
                                local uid=mt:match("%[ZAYN_DJ_REVOKE:([%w_]+)%]"); if uid then djPermittedUsers[uid]=nil end; continue
                            end
                            if mt:find("%[ZAYN_DJ_PLAY:") then
                                local yId=mt:match("%[ZAYN_DJ_PLAY:([%w_-]+)%]"); local sUid=mt:match("||([%w_]+)$")
                                if yId and sUid and hasDjPerm(sUid) then
                                    local dn=activeScriptUsers[sUid] and activeScriptUsers[sUid].displayName or "A DJ"
                                    lastDjPlayFirebaseKey=key; DownloadAndPlayYTAudio(yId,dn)
                                elseif yId and sUid and not hasDjPerm(sUid) then
                                    task.spawn(function() pcall(function() reqFunc({Url=FIREBASE_URL..DB_PATH.."/"..key..".json",Method="DELETE"}) end) end)
                                end; continue
                            end
                            if mt:find("%[ZAYN_DJ_STOP%]") then
                                local sUid=mt:match("||([%w_]+)$")
                                if sUid and hasDjPerm(sUid) then
                                    local dn=activeScriptUsers[sUid] and activeScriptUsers[sUid].displayName or "A DJ"
                                    StopZaynDJ(); addMessageToChat("System","⏹ "..dn.." stopped the music.",true,nil,"Server")
                                end; continue
                            end
                            if mt:find("%[ZAYN_SYNC%]") then
                                local tS,tSig,sUid=mt:match("%[ZAYN_SYNC%] (%d+):(%d+)%s*||([%w_]+)")
                                if sUid and tS and tSig then
                                    if math.abs(os.time()-tonumber(tS))<=120 and tSig==genSig("SYNC",sUid,tS) then
                                        local dn,un=getStrictIdentity(sUid)
                                        if not isFirstLoad and sUid~=myUserId then
                                            if not activeScriptUsers[sUid] or not activeScriptUsers[sUid].welcomed then
                                                addMessageToChat("System","👋 "..dn.." joined!",true,nil,"Server")
                                            end
                                        end
                                        if not activeScriptUsers[sUid] then
                                            activeScriptUsers[sUid]={displayName=dn,name=un,lastSeen=os.time(),welcomed=true}
                                        else activeScriptUsers[sUid].lastSeen=os.time(); activeScriptUsers[sUid].welcomed=true end
                                    end
                                end; continue
                            end
                            if mt:find("%[ZAYN_PROFILE_SYNC%]") then
                                local pUid=mt:match("%[ZAYN_PROFILE_SYNC%] ([%w_]+)")
                                if pUid then task.spawn(function()
                                    local pR=reqFunc({Url=FIREBASE_URL.."profiles/"..pUid..".json",Method="GET"})
                                    if pR.Success and pR.Body~="null" then pcall(function() customProfiles[pUid]=HttpService:JSONDecode(pR.Body) end) end
                                end) end; continue
                            end
                            if mt:find("%[ZAYN_TITLE_SYNC%]") then
                                local cmd=mt:match("%[ZAYN_TITLE_SYNC%] (%w+)")
                                if cmd=="SET" then
                                    local u,c,t,e=mt:match("SET::([%w_]+)::(%S+)::(.-)::(%d+)")
                                    if u and t then _internalTitles[u]={text=t,color=c,expire=tonumber(e)} end
                                elseif cmd=="REMOVE" then local u=mt:match("REMOVE::([%w_]+)"); if u then _internalTitles[u]=nil end
                                elseif cmd=="CLEARALL" then _internalTitles={} end; continue
                            end

                            if isFirstLoad then continue end
                            if mt:find("%[SYSTEM%]") then
                                addMessageToChat("System",mt:match("%[SYSTEM%]%s*:%s*(.*)"),true,nil,"Server"); continue
                            end

                            local sN,sM,sU,cN=parseMessage(mt)
                            if sN and sM and tostring(sU)~=myUserId then
                                if not activeScriptUsers[sU] then activeScriptUsers[sU]={displayName=cN,name=cN,lastSeen=os.time(),welcomed=true}
                                else activeScriptUsers[sU].lastSeen=os.time() end

                                if not spamTracker[sU] then spamTracker[sU]={} end
                                table.insert(spamTracker[sU],os.time())
                                if #spamTracker[sU]>4 then table.remove(spamTracker[sU],1) end
                                if #spamTracker[sU]==4 and (spamTracker[sU][4]-spamTracker[sU][1]<=2) then
                                    addMessageToChat("System","🔇 Auto-muted "..cN.." (spam).",true,nil,"Server")
                                    spamTracker[sU]={} ; continue
                                end

                                if myAfkReason then
                                    if string.find(string.lower(sM),"@"..string.lower(cleanMyName),1,true) or
                                       string.find(string.lower(sM),"@"..string.lower(myUser),1,true) then
                                        if os.time()-lastAfkReply>10 then
                                            lastAfkReply=os.time()
                                            task.spawn(function() task.wait(0.5); sendMsg("🤖 [Auto-Reply]: AFK — "..myAfkReason) end)
                                        end
                                    end
                                end

                                addMessageToChat(cN,sM,false,tonumber(sU),"Server",key)
                                showNotif(cN,sM,false,tonumber(sU),"Server",nil)
                                local tp=tonumber(sU) and Players:GetPlayerByUserId(tonumber(sU))
                                if tp then createBubble(cN,sM,tp) end
                            end
                        end
                    end
                end
                isFirstLoad=false
                for uid,d in pairs(activeScriptUsers) do
                    if uid~=myUserId and (os.time()-(d.lastSeen or 0))>120 then activeScriptUsers[uid]=nil end
                end
            end)
            task.wait(1.5)
        end
    end)

