                        table.insert(messageQueue, {text="[ZAYN_DJ_GRANT:" .. tgt .. "]", timestamp=os.time()}); processQueue()
                        addMessageToChat("System", "✅ DJ granted to " .. tU, true, nil, "Server")
                    end
                end; return
            end
            if txt:lower():sub(1,10) == "/djrevoke " then
                local tU = txt:sub(11):match("^%s*(%S+)"); if tU then
                    local tgt = nil
                    for u,d in pairs(activeScriptUsers) do if d.name:lower()==tU:lower() or d.displayName:lower()==tU:lower() then tgt=u; break end end
                    if tgt then
                        pcall(function() reqFunc({Url = FIREBASE_URL .. "dj_permissions/" .. tgt .. ".json", Method = "DELETE"}) end)
                        table.insert(messageQueue, {text="[ZAYN_DJ_REVOKE:" .. tgt .. "]", timestamp=os.time()}); processQueue()
