        ov.MouseButton1Click:Connect(function() pcall(function() cg:Destroy() end) end)
        local mp = UserInputService:GetMouseLocation()
        local mf = Instance.new("Frame", cg)
        mf.Size=UDim2.new(0,170,0,0); mf.AutomaticSize=Enum.AutomaticSize.Y
        mf.Position=UDim2.new(0,math.min(mp.X,580),0,math.min(mp.Y,380))
        mf.BackgroundColor3=Colors.BG2; mf.BackgroundTransparency=0.04; mf.BorderSizePixel=0
