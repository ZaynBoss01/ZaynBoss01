        elseif txt:lower():sub(1,8) == "/djplay " or txt:lower() == "/djstop" then
            addMessageToChat("System", "❌ No DJ permission! Ask admin: /djgrant", true, nil, "Server"); return
        end

        if serverReplyContext and not txt:find("%[STICKER:") and not txt:find("%[PHOTO:") and not txt:find("%[VOICE:") then
