    sendMsg = function(txt)
        txt = tostring(txt):gsub("^%s+", ""):gsub("%s+$", "")
        if txt == "" or isBlacklisted then return end

        if txt:lower() == "/help" then
            addMessageToChat("[SYSTEM]", "🌟 Z CHAT V49.2 COMMANDS\n\n/tr [lang] [msg] · /setlang [lang]\n/img [url] · /voice [id] · /snap [msg]\n/djplay [yt_url] · /djstop · /djmute · /djunmute\nSwipe ← → to Reply | Hold to Unsend/Copy/Translate", true, nil, "Server"); return
