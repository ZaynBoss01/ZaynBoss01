    local messageQueue, queueProcessing = {}, false
    function processQueue()
        if queueProcessing or not reqFunc then return end; queueProcessing = true
        task.spawn(function()
            while #messageQueue > 0 do
                local msgData = messageQueue[1]
                local s, r = pcall(function() return reqFunc({Url = FIREBASE_URL .. DB_PATH .. ".json", Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(msgData)}) end)
                if s and r and r.Success then table.remove(messageQueue, 1) else task.wait(0.5) end; task.wait()
            end
            queueProcessing = false
        end)
