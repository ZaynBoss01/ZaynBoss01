    local function createBubble(dispName, msg, targetPlayer)
        if not targetPlayer or not targetPlayer.Character then return end
        local cm = msg
        local _, rest = msg:match("^↪️ %[Replying to (.-)%]\n(.*)")
        if rest then cm = rest end
        if cm:match("^%[STICKER:") then cm = "[Sticker ✦]"
        elseif cm:match("^%[PHOTO:") then cm = "[Photo 📷]"
        elseif cm:match("^%[SNAP%]") then cm = "[Snap 🔥]"
        elseif cm:match("^%[VOICE:") then cm = "[Voice ♪]" end
        pcall(function() game:GetService("TextChatService"):DisplayBubble(targetPlayer.Character, cm) end)
    end

