                -- Get FBKey from container attribute (reliable)
                local storedFbKey = masterContainer:GetAttribute("FBKey") or fbKey or ""
                local isMyMsg2 = isMyMessage
                local touchStart, isSwiping, hasMoved, holdTimer, isHolding = nil, false, false, nil, false
                local swipeOffset = 0

                local function smoothSetBubbleX(targetX)
                    local maxX = 80; local resistance = 0.65
                    local finalX = math.abs(targetX) <= maxX and (targetX * resistance) or (maxX * resistance * (targetX > 0 and 1 or -1))
                    swipeOffset = finalX
                    pcall(function() rowFrame.Position = UDim2.new(0, finalX, 0, 0) end)
                end

                local function snapBubbleBack(withOvershoot)
                    if withOvershoot then
                        local dir = swipeOffset > 0 and 1 or -1
                        safeTween(rowFrame, {Position = UDim2.new(0, dir * 20, 0, 0)}, 0.07, Enum.EasingStyle.Sine)
                        task.wait(0.07)
                    end
                    safeTween(rowFrame, {Position = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                    swipeOffset = 0
                end

                local function triggerReply()
                    local replyText = isSnap and "[Snap 🔥]" or cleanMsgTxt
                    if contextType2 == "DM" then updateDmReplyState(senderName2, replyText)
                    else updateServerReplyState(senderName2, replyText) end
                    pcall(function()
                        local sfx = Instance.new("Sound", UI_PARENT)
                        sfx.SoundId = "rbxassetid://6895088918"; sfx.Volume = 0.5; sfx:Play()
                        task.wait(0.4); sfx:Destroy()
                    end)
                end

                masterContainer.InputBegan:Connect(function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
                    touchStart = input.Position; isSwiping = false; hasMoved = false; isHolding = true
                    if holdTimer then task.cancel(holdTimer) end
                    holdTimer = task.delay(0.45, function()
                        if isHolding and not hasMoved then
                            isHolding = false
                            pcall(function()
                                local sfx = Instance.new("Sound", UI_PARENT)
                                sfx.SoundId = "rbxassetid://6895088918"; sfx.Volume = 0.4; sfx:Play()
                                task.wait(0.3); sfx:Destroy()
                            end)
                            local origX = swipeOffset
                            for _, dx in ipairs({5, -5, 3, -3, 0}) do
                                if not rowFrame or not rowFrame.Parent then break end
                                safeTween(rowFrame, {Position = UDim2.new(0, origX + dx, 0, 0)}, 0.05)
                                task.wait(0.05)
                            end
                            openMessageContextMenu(
                                msgTextLabel, messageText2, senderName2, contextType2,
                                masterContainer, isMyMsg2, storedFbKey, contextType2, convoKeyLocal
                            )
                        end
                    end)
                end)

                masterContainer.InputChanged:Connect(function(input)
                    if not touchStart then return end
                    if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
                    local delta = input.Position - touchStart
                    if delta.Magnitude > 6 then hasMoved = true; isHolding = false end
                    if math.abs(delta.X) > 10 and math.abs(delta.X) > math.abs(delta.Y) * 1.3 then
                        isSwiping = true; smoothSetBubbleX(delta.X)
                    end
                end)

                masterContainer.InputEnded:Connect(function(input)
                    if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
                    isHolding = false
                    if holdTimer then task.cancel(holdTimer); holdTimer = nil end
                    if touchStart and isSwiping then
                        local delta = input.Position - touchStart
                        if math.abs(delta.X) > 50 and math.abs(delta.X) > math.abs(delta.Y) * 1.3 then
                            triggerReply(); snapBubbleBack(true)
                        else snapBubbleBack(false) end
                    end
                    touchStart = nil; isSwiping = false
                end)
            end

            attachSwipeAndHold(masterContainer, cleanName, cleanMsgTxt, chatType)

            if isSnap then
                task.delay(10, function()
                    if masterContainer and masterContainer.Parent then
                        for _, v in ipairs(masterContainer:GetDescendants()) do
                            if v:IsA("TextLabel") or v:IsA("TextButton") then pcall(function() safeTween(v, {TextTransparency = 1}, 0.5) end)
                            elseif v:IsA("ImageLabel") or v:IsA("ImageButton") then pcall(function() safeTween(v, {ImageTransparency = 1}, 0.5) end) end
                        end
                        task.wait(0.5); pcall(function() masterContainer:Destroy() end)
                    end
                end)
            end

            task.spawn(function()
                task.wait(0.1)
                if not targetFrame or masterContainer.Visible == false then return end
                local isNearBottom = targetFrame.CanvasPosition.Y >= (targetLayout.AbsoluteContentSize.Y - targetFrame.AbsoluteWindowSize.Y - 100)
                if isNearBottom or tostring(userId) == myUserId then
                    local maxScroll = targetLayout.AbsoluteContentSize.Y - targetFrame.AbsoluteSize.Y + 20
                    if maxScroll > 0 then safeTween(targetFrame, {CanvasPosition = Vector2.new(0, maxScroll)}, 0.18, Enum.EasingStyle.Sine) end
                end
                local messages = {}
                for _, child in ipairs(targetFrame:GetChildren()) do if child:IsA("Frame") then table.insert(messages, child) end end
                if #messages > MAX_MESSAGES_ON_SCREEN then
                    table.sort(messages, function(a, b) return a.LayoutOrder < b.LayoutOrder end)
                    for i = 1, #messages - MAX_MESSAGES_ON_SCREEN do pcall(function() messages[i]:Destroy() end) end
                end
            end)
        end)
    end

