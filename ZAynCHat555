                processQueue(); addMessageToChat("System", "🧹 All titles cleared.", true, nil, "Server"); return
            end
            if txt:lower():sub(1,6) == "/gban " then
                local t = txt:sub(7):gsub("%s+",""); local tId=nil
                for u,d in pairs(activeScriptUsers) do if d.name:lower()==t:lower() or d.displayName:lower()==t:lower() then tId=u; break end end
                if tId then
                    reqFunc({Url=FIREBASE_URL..BLACKLIST_DB_PATH..tId..".json", Method="PUT", Headers={["Content-Type"]="application/json"}, Body=HttpService:JSONEncode(true)})
                    table.insert(messageQueue, {text="["..SERVER_ID.."] [GBAN] "..tId.." ||"..myUserId.."_"..SECURE_AUTH_KEY, timestamp=os.time()})
                    processQueue(); addMessageToChat("[SYSTEM]", "🔨 Banned: "..t, true, nil, "Server")
