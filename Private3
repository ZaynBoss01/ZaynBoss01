    -- Chat Functions
    local function addMessage(text, color)
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 0, 0)
        label.AutomaticSize = Enum.AutomaticSize.Y
        label.BackgroundTransparency = 1
        label.Text = text
        label.TextColor3 = color
        label.Font = Enum.Font.GothamMedium
        label.TextSize = 12
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextWrapped = true
        label.Parent = scroll
        task.wait()
        scroll.CanvasPosition = Vector2.new(0, scroll.CanvasSize.Y.Offset)
    end
    
    local function addSystemMessage(text)
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 0, 0)
        label.AutomaticSize = Enum.AutomaticSize.Y
        label.BackgroundTransparency = 1
        label.Text = "📢 " .. text
        label.TextColor3 = Color3.fromRGB(255, 200, 100)
        label.Font = Enum.Font.GothamMedium
        label.TextSize = 11
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextWrapped = true
        label.Parent = scroll
        task.wait()
        scroll.CanvasPosition = Vector2.new(0, scroll.CanvasSize.Y.Offset)
    end
    
    local function updateActiveCount()
        local count = #activeUsers
        if count == 0 then
            onlineLabel.Text = "👥 Active: 1 (You)"
            if not table.find(activeUsers, Player.Name) then
                table.insert(activeUsers, Player.Name)
            end
        else
            onlineLabel.Text = "👥 Active: " .. count
        end
    end
    
    -- Send Message via RemoteEvent
    local function sendMessage(msg)
        if msg == "" or not msg then return end
        
        local role = SUPER_ADMINS[Player.Name] and "OWNER" or "USER"
        local prefix = role == "OWNER" and "👑 [OWNER] " or "👤 [USER] "
        
        addMessage(prefix .. Player.Name .. ": " .. msg, Color3.new(1, 1, 1))
        
        -- Bubble Chat
        pcall(function()
            if Player.Character and Player.Character:FindFirstChild("Head") then
                local bubble = Instance.new("BillboardGui")
                bubble.Size = UDim2.new(0, 200, 0, 40)
                bubble.StudsOffset = Vector3.new(0, 2.5, 0)
                bubble.AlwaysOnTop = true
                bubble.Parent = Player.Character.Head
                
                local text = Instance.new("TextLabel")
                text.Size = UDim2.new(1, 0, 1, 0)
                text.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                text.BackgroundTransparency = 0.4
                text.TextColor3 = Color3.new(1, 1, 1)
                text.Text = msg
                text.Font = Enum.Font.GothamMedium
                text.TextSize = 12
                text.TextWrapped = true
                text.Parent = bubble
                Instance.new("UICorner", text).CornerRadius = UDim.new(0, 8)
                
                game:GetService("Debris"):AddItem(bubble, 3)
            end
        end)
        
        -- Send via RemoteEvent to all script users
        if RemoteEvent then
            RemoteEvent:FireAllClients({
                type = "message",
                user = Player.Name,
                msg = msg,
                role = role,
                timestamp = os.time()
            })
        end
    end
    
    -- Receive Message Handler
    local function onMessageReceived(data)
        if data.type == "message" and data.user ~= Player.Name then
            -- Check for duplicate
            local msgKey = data.user .. data.msg .. data.timestamp
            local alreadySeen = false
            for _, seen in ipairs(messageHistory) do
                if seen == msgKey then
                    alreadySeen = true
                    break
                end
            end
            
            if not alreadySeen then
                table.insert(messageHistory, msgKey)
                if #messageHistory > 200 then
                    table.remove(messageHistory, 1)
                end
                
                -- Add to active users
                local userExists = false
                for _, u in ipairs(activeUsers) do
                    if u == data.user then
                        userExists = true
                        break
                    end
                end
                if not userExists then
                    table.insert(activeUsers, data.user)
                    updateActiveCount()
                    addSystemMessage("✨ " .. data.user .. " joined the chat!")
                end
                
                -- Show message
                if data.role == "OWNER" then
                    addMessage("👑 [OWNER] " .. data.user .. ": " .. data.msg, Color3.new(1, 1, 1))
                else
                    addMessage("👤 [USER] " .. data.user .. ": " .. data.msg, Color3.new(1, 1, 1))
                end
            end
        elseif data.type == "join" and data.user ~= Player.Name then
            local userExists = false
            for _, u in ipairs(activeUsers) do
                if u == data.user then
                    userExists = true
                    break
                end
            end
            if not userExists then
                table.insert(activeUsers, data.user)
                updateActiveCount()
                addSystemMessage("✨ " .. data.user .. " joined the chat!")
            end
        elseif data.type == "leave" and data.user ~= Player.Name then
            for i, u in ipairs(activeUsers) do
                if u == data.user then
                    table.remove(activeUsers, i)
                    updateActiveCount()
                    addSystemMessage("👋 " .. data.user .. " left the chat!")
                    break
                end
            end
        end
    end
    
    -- Heartbeat to show online status
    local function sendHeartbeat()
        if RemoteEvent then
            RemoteEvent:FireAllClients({
                type = "heartbeat",
                user = Player.Name,
                timestamp = os.time()
            })
        end
    end
    
    -- Cleanup inactive users
    local lastHeartbeatTime = {}
    local function cleanupInactive()
        local now = os.time()
        for i, user in ipairs(activeUsers) do
            if user ~= Player.Name then
                local lastTime = lastHeartbeatTime[user] or 0
                if now - lastTime > 60 then
                    table.remove(activeUsers, i)
                    updateActiveCount()
                    addSystemMessage("👋 " .. user .. " left the chat!")
                end
            end
        end
    end
    
    -- Heartbeat receiver
    local function onHeartbeat(data)
        if data.user ~= Player.Name then
            lastHeartbeatTime[data.user] = data.timestamp or os.time()
            
            -- Add to active if not exists
            local userExists = false
            for _, u in ipairs(activeUsers) do
                if u == data.user then
                    userExists = true
                    break
                end
            end
            if not userExists then
                table.insert(activeUsers, data.user)
                updateActiveCount()
                addSystemMessage("✨ " .. data.user .. " joined the chat!")
            end
        end
    end
    
    -- Connect RemoteEvent
    if RemoteEvent then
        RemoteEvent.OnClientEvent:Connect(function(data)
            if data.type == "message" then
                onMessageReceived(data)
            elseif data.type == "heartbeat" then
                onHeartbeat(data)
            elseif data.type == "join" then
                onMessageReceived(data)
            elseif data.type == "leave" then
                onMessageReceived(data)
            end
        end)
    end
    
    -- Input Handler
    inputBox.FocusLost:Connect(function(enter)
        if enter and inputBox.Text ~= "" then
            sendMessage(inputBox.Text)
            inputBox.Text = ""
        end
    end)
    
    -- RGB Border Effect
    task.spawn(function()
        local hue = 0
        while true do
            hue = (hue + 0.002) % 1
            local color = Color3.fromHSV(hue, 1, 0.9)
            pcall(function()
                stroke.Color = color
                toggleStroke.Color = color
            end)
            task.wait(0.05)
        end
    end)
    
    -- Initialization
    task.spawn(function()
        task.wait(1)
        
        -- Add self to active users
        table.insert(activeUsers, Player.Name)
        updateActiveCount()
        
        -- Send join message
        if RemoteEvent then
            RemoteEvent:FireAllClients({
                type = "join",
                user = Player.Name,
                timestamp = os.time()
            })
        end
        
        -- Start heartbeat
        task.spawn(function()
            while true do
                task.wait(30)
                sendHeartbeat()
            end
        end)
        
        -- Cleanup inactive users
        task.spawn(function()
            while true do
                task.wait(60)
                cleanupInactive()
            end
        end)
        
        -- Welcome messages
        addSystemMessage("✨ Welcome to Zayn Private Chat!")
        addSystemMessage("💬 Brookhaven Compatible Edition!")
        addSystemMessage("👤 You are: " .. Player.Name)
        addSystemMessage("🎨 Click THEMES to change colors")
        addSystemMessage("📌 Drag the title bar to move this window")
    end)
    
    return main
end

